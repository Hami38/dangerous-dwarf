---
/* Hamburger.astro */
---

<button 
  id="hamburger-button" 
  class="flex flex-col justify-center items-center w-12 h-12 focus:outline-none cursor-pointer group active:scale-90 transition-transform z-[220]"
  aria-label="Menu"
>
  <div class="relative w-6 h-3 flex flex-col justify-between overflow-visible">
    <span class="line line-top"></span>
    <span class="line line-bottom"></span>
  </div>
</button>

<style>
  .line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: white;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  /* Klasa nadawana przez JavaScript */
  #hamburger-button.is-active .line-top {
    transform: translateY(5px) rotate(45deg);
  }

  #hamburger-button.is-active .line-bottom {
    transform: translateY(-5px) rotate(-45deg);
  }
</style>

<script>
  // Ten skrypt uruchomi się tylko raz dla tego komponentu
  const btn = document.getElementById('hamburger-button');
  const menu = document.getElementById('mobile-menu');
  const body = document.body;

  btn?.addEventListener('click', () => {
    const isActive = btn.classList.toggle('is-active');
    menu?.classList.toggle('active');
    
    if (isActive) {
      body.classList.add('menu-open');
    } else {
      body.classList.remove('menu-open');
    }
  });

  // Słuchamy na event zamknięcia menu (np. po kliknięciu w link)
  window.addEventListener('close-menu', () => {
    btn?.classList.remove('is-active');
    menu?.classList.remove('active');
    body.classList.remove('menu-open');
  });
</script>