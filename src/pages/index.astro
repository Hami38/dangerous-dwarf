---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import HeroExpandImage from '../components/HeroExpandImage.astro';
import HeroExpandMobile from '../components/HeroExpandMobile.astro';
---

<Layout title="Kamil Wardak | Design Strategist">

  <div id="preloader" aria-hidden="true">
    <div class="preloader-content">
      <span id="welcome-text">∙ Cześć</span>
    </div>
  </div>

  <!-- POPRAWKA: usunięto zbędny <main> — jest już w Layout.astro -->
  <div class="bg-[#0c0a09]">
    <Hero />
    <HeroExpandImage />
    <HeroExpandMobile />

    <section class="h-screen flex items-center justify-center border-t border-white/5">
      <p class="text-white/20 font-medium tracking-widest uppercase text-sm">Przewijaj dalej</p>
    </section>
  </div>

</Layout>



<script>
  const words = ["∙ Hello", "∙ Hallo", "∙ Hola", "∙ こんにちは", "∙ 你好", "∙ Witaj"];
  let currentIndex = 0;

  const textElement = document.getElementById("welcome-text");
  const preloader = document.getElementById("preloader");

  function updateText() {
    if (textElement && currentIndex < words.length) {
      textElement.style.opacity = "0";
      setTimeout(() => {
        textElement.textContent = words[currentIndex];
        textElement.style.opacity = "1";
        currentIndex++;
        setTimeout(updateText, 250);
      }, 150);
    } else if (preloader) {
      setTimeout(() => {
        preloader.classList.add("preloader-hidden");
        document.body.style.overflow = "auto";

        // POPRAWKA: emitujemy event — Layout.astro na niego czeka
        window.dispatchEvent(new CustomEvent('preloaderFinished'));

      }, 500);
    }
  }

  document.body.style.overflow = "hidden";
  setTimeout(updateText, 400);
</script>



<style is:global>
  body { background-color: #0c0a09; margin: 0; }

  #preloader {
    position: fixed; inset: 0; background-color: #0c0a09;
    display: flex; justify-content: center; align-items: center;
    z-index: 9999; transition: transform 0.8s cubic-bezier(0.85, 0, 0.15, 1);
  }

  .preloader-hidden { transform: translateY(-100%); pointer-events: none; }
  #welcome-text { font-size: 2.5rem; font-weight: 700; color: #BAF52A; transition: opacity 0.15s; }
</style>