---
import '../styles/global.css';
import Header from '../components/Header.astro';
import PageTransition from '../components/PageTransition.astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
	title?: string;
}

const { title = "Kamil Wardak | Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
		<title>{title}</title>
		<!-- Ustawia stan przejścia PRZED pierwszym renderem — zero flashu -->
		<script is:inline>
			if (sessionStorage.getItem('ct')) {
				document.documentElement.classList.add('curtain-ready');
			}
			if (sessionStorage.getItem('np')) {
				document.documentElement.classList.add('no-preloader');
			}
		</script>
	</head>
	<body>
		<PageTransition />
		<Header />
		<slot />
		<SpeedInsights />

		<script>
			import { initBlockReveals } from '../utils/blockReveal';

			const run = () => {
				if (document.body.dataset.revealsInit) return;
				document.body.dataset.revealsInit = 'true';
				initBlockReveals();
			};

			// Ścieżka 1: strona główna — czekamy na koniec preloadera
			window.addEventListener('preloaderFinished', run, { once: true });

			// Ścieżka 2: strony bez preloadera — czekamy na koniec zasłony
			window.addEventListener('curtainDone', run, { once: true });

			// Ścieżka 3: fallback dla bezpośredniego wejścia URL — tylko gdy brak preloadera
			document.addEventListener('DOMContentLoaded', () => {
				if (!document.getElementById('preloader')) {
					setTimeout(() => run(), 150);
				}
			});
		</script>
	</body>
</html>

<style is:global>
	.action-reveal {
		opacity: 0;
		transform: translateY(20px);
	}

	/* Ukryj preloader przed pierwszym renderem gdy przyszliśmy z nawigacji */
	html.no-preloader #preloader {
		display: none !important;
	}

	/* Zasłona aktywna od razu — zanim JS zdąży się uruchomić */
	html.curtain-ready #curtain {
		transform: translateY(0%) !important;
	}
</style>
