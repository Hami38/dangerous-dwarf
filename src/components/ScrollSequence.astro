---
/* src/components/ScrollSequence.astro */
---

<section class="sequence-wrapper bg-[#0c0a09]">
  <div class="sticky-container">
    <canvas id="sequence-canvas"></canvas>
    
    <div class="overlay-content">
      <div class="achievements-grid">
        <div class="stat-card">
          <span class="label">ING Bank Śląski</span>
          <h3>+40%</h3>
          <p>Wzrost konwersji w procesach korporacyjnych dzięki GenAI.</p>
        </div>
        <div class="stat-card">
          <span class="label">Sektor Medyczny</span>
          <h3>UX Strategy</h3>
          <p>Skrócenie czasu diagnostyki o 15% poprzez redesign systemów.</p>
        </div>
        <div class="stat-card">
          <span class="label">Sektor Zbrojeniowy</span>
          <h3>Complex Systems</h3>
          <p>Projektowanie interfejsów krytycznych o zerowym marginesie błędu.</p>
        </div>
        <div class="stat-card">
          <span class="label">Innowacje</span>
          <h3>12 Lat</h3>
          <p>Doświadczenia w transformacji cyfrowej liderów rynkowych.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sequence-wrapper {
    position: relative;
    width: 100%;
    z-index: 10;
  }

  .sticky-container {
    height: 100vh;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  #sequence-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-color: #0c0a09;
  }

  .overlay-content {
    position: relative;
    z-index: 20;
    width: 100%;
    max-width: 1200px;
    padding: 2rem;
    pointer-events: none; /* Pozwala scrollować "przez" tekst */
  }

  .achievements-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .stat-card {
    pointer-events: auto; /* Przywraca klikalność kafelków */
    background: rgba(12, 10, 9, 0.6); 
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 3rem;
    border-radius: 24px;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .stat-card:hover {
    border-color: #BAF52A;
    transform: translateY(-8px);
    background: rgba(12, 10, 9, 0.8);
  }

  .stat-card .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: #BAF52A;
    letter-spacing: 0.2em;
    font-weight: 700;
  }

  .stat-card h3 {
    font-size: 4rem;
    font-weight: 800;
    color: white;
    margin: 0.5rem 0;
    line-height: 1;
  }

  .stat-card p {
    color: #a8a29e;
    line-height: 1.6;
    margin: 0;
    font-size: 1.1rem;
    max-width: 320px;
  }

  @media (max-width: 1024px) {
    .stat-card h3 { font-size: 3rem; }
    .achievements-grid { gap: 1.5rem; }
  }

  @media (max-width: 768px) {
    .achievements-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .stat-card { padding: 2rem; }
    .stat-card h3 { font-size: 2.5rem; }
    .overlay-content { padding: 1rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const canvas = document.getElementById('sequence-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  
  const frameCount = 48;
  const currentFrame = (index: number) => `/sequence/${(index + 1).toString().padStart(6, '0')}.webp`;

  const images: HTMLImageElement[] = [];
  const sequence = { frame: 0 };

  // 1. Preloading obrazów
  for (let i = 0; i < frameCount; i++) {
    const img = new Image();
    img.src = currentFrame(i);
    images.push(img);
  }

  // 2. Funkcja renderująca dopasowana do ekranu (Cover)
  function render() {
    if (!ctx || !images[sequence.frame]) return;
    const img = images[sequence.frame];
    
    const canvasWidth = window.innerWidth;
    const canvasHeight = window.innerHeight;
    canvas.width = canvasWidth;
    canvas.height = canvasHeight;

    const imgRatio = img.width / img.height;
    const canvasRatio = canvasWidth / canvasHeight;

    let drawWidth, drawHeight, drawX, drawY;

    if (canvasRatio > imgRatio) {
      drawWidth = canvasWidth;
      drawHeight = canvasWidth / imgRatio;
      drawX = 0;
      drawY = (canvasHeight - drawHeight) / 2;
    } else {
      drawWidth = canvasHeight * imgRatio;
      drawHeight = canvasHeight;
      drawX = (canvasWidth - drawWidth) / 2;
      drawY = 0;
    }

    ctx.clearRect(0, 0, canvasWidth, canvasHeight);
    
    // Lekkie przyciemnienie całego tła dla czytelności tekstu (0.4 = 40% widoczności)
    ctx.globalAlpha = 0.5;
    ctx.drawImage(img, drawX, drawY, drawWidth, drawHeight);
    ctx.globalAlpha = 1.0;
  }

  // 3. Timeline GSAP
  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: ".sequence-wrapper",
      start: "top top",
      end: "+=300%", // Scroll trwa przez 3 wysokości ekranu
      scrub: 1,      // Płynne podążanie za scrollem
      pin: true,     // Blokada sekcji na ekranie
    }
  });

  // Animacja klatek
  tl.to(sequence, {
    frame: frameCount - 1,
    snap: "frame",
    onUpdate: render,
    duration: 3
  }, 0);

  // Animacja kafelków (wjeżdżają od dołu z opóźnieniem)
  tl.from(".stat-card", {
    y: 100,
    opacity: 0,
    stagger: 0.2,
    duration: 1.5,
    ease: "power4.out"
  }, 0.6); // Startują w 1/5 trwania animacji tła

  // 4. Obsługa zmiany rozmiaru okna
  window.addEventListener('resize', render);
  
  // Inicjalny render po załadowaniu pierwszego zdjęcia
  images[0].onload = render;
</script>