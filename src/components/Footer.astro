---
/* src/components/Footer.astro */
import LinkedInButton from './LinkedInButton.astro';

const navLinks = [
  { label: 'O mnie',     href: '#' },
  { label: 'Prace',      href: '#' },
  { label: 'Leadership', href: '#' },
];

const year = new Date().getFullYear();
---

<footer class="footer relative bg-[#0c0a09] overflow-hidden px-6 pt-24 pb-10">

  <!-- Dekoracyjna wielka litera tła -->
  <span class="footer-bg-letter" aria-hidden="true">KW</span>

  <!-- Górna zielona linia -->
  <div class="max-w-4xl mx-auto">
    <div class="w-full h-px bg-[#BAF52A]/20 mb-16"></div>
  </div>

  <div class="max-w-4xl mx-auto relative z-10">

    <!-- GŁÓWNE CTA -->
    <div class="footer-cta-block mb-20 md:mb-24">
      <p class="footer-label text-[#BAF52A] text-xs normalcase tracking-[0.2em] font-extrabold mb-5 opacity-0 footer-reveal" data-delay="0">
        Zaczynamy?
      </p>

      <h2 class="footer-headline opacity-0 footer-reveal" data-delay="80">
        Masz projekt.<br/>
        <span class="footer-headline-accent">Porozmawiajmy.</span>
      </h2>

      <p class="footer-sub text-stone-400 text-base md:text-lg font-medium max-w-lg mt-6 leading-relaxed opacity-0 footer-reveal" data-delay="160">
        Szukam nowych wyzwań, w których mogę połączyć strategię, design i technologię. Napisz — odpiszę szybko.
      </p>

      <!-- Główny przycisk CTA -->
      <div class="mt-10 opacity-0 footer-reveal" data-delay="240">
        <a
          href="mailto:kamil.wardak97@gmail.com"
          class="footer-cta-btn group"
        >
          <span>kamil.wardak97@gmail.com</span>
          <div class="footer-cta-icon">
            <svg class="icon-default" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <svg class="icon-hover" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14m-7-7 7 7-7 7"/>
            </svg>
          </div>
        </a>
      </div>
    </div>

    <!-- DOLNY PASEK -->
    <div class="w-full h-px bg-white/5 mb-8 opacity-0 footer-reveal" data-delay="320"></div>

    <div class="footer-bottom opacity-0 footer-reveal" data-delay="380">
      <!-- Lewa: copyright -->
      <p class="footer-copy text-white/25 text-xs font-medium tracking-wide">
        © {year} Kamil Wardak. Wszelkie prawa zastrzeżone.
      </p>

      <!-- Środek: nawigacja -->
      <nav class="footer-nav">
        {navLinks.map((link) => (
          <a href={link.href} class="footer-nav-link">{link.label}</a>
        ))}
      </nav>

      <!-- Prawa: LinkedIn -->
      <div class="footer-social">
        <LinkedInButton />
      </div>
    </div>

  </div>

  <!-- Efekt świecenia z dołu -->
  <div class="footer-glow" aria-hidden="true"></div>
</footer>

<style>
  .footer {
    position: relative;
  }

  /* Dekoracyjna litera tła */
  .footer-bg-letter {
    position: absolute;
    bottom: -2rem;
    right: -2rem;
    font-size: clamp(8rem, 25vw, 18rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 1;
    color: var(--brand-main);
    opacity: 0.025;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* Glow efekt na dole */
  .footer-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #BAF52A, transparent);
    opacity: 0.35;
    pointer-events: none;
  }

  /* Label */
  .footer-label {
    display: block;
  }

  /* Headline */
  .footer-headline {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: white;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .footer-headline-accent {
    background: linear-gradient(135deg, #BAF52A 0%, #e8ff8a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* CTA Button */
  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 14px 32px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 600;
    background-color: #BAF52A;
    color: #000;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    white-space: nowrap;
    height: 52px;
    position: relative;
    overflow: hidden;
  }

  .footer-cta-btn:hover {
    background-color: #000;
    color: #BAF52A;
    box-shadow: 0 0 0 1px #BAF52A, 0 0 30px rgba(186, 245, 42, 0.2);
  }

  .footer-cta-icon {
    position: relative;
    width: 18px;
    height: 18px;
    overflow: hidden;
  }

  .footer-cta-icon .icon-default,
  .footer-cta-icon .icon-hover {
    position: absolute;
    inset: 0;
    transition: transform 0.4s cubic-bezier(0.6, 0.01, 0.05, 0.95);
  }

  .footer-cta-icon .icon-hover {
    transform: translateY(100%);
  }

  .footer-cta-btn:hover .footer-cta-icon .icon-default {
    transform: translateY(-100%);
  }

  .footer-cta-btn:hover .footer-cta-icon .icon-hover {
    transform: translateY(0);
  }

  /* Dolny pasek */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    margin: 0;
    flex-shrink: 0;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .footer-nav-link {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    transition: color 0.3s ease;
    white-space: nowrap;
  }

  .footer-nav-link:hover {
    color: #BAF52A;
  }

  .footer-social {
    flex-shrink: 0;
  }

  /* Stany startowe dla animacji */
  .footer-reveal {
    transform: translateY(20px);
  }

  /* Responsywność */
  @media (max-width: 640px) {
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .footer-nav {
      gap: 1.5rem;
    }

    .footer-cta-btn {
      font-size: 13px;
      padding: 12px 22px;
      height: 46px;
    }

    .footer-bg-letter {
      right: -1rem;
      bottom: -1rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const revealEls = document.querySelectorAll<HTMLElement>('.footer-reveal');

  ScrollTrigger.create({
    trigger: 'footer',
    start: 'top 85%',
    once: true,
    onEnter: () => {
      revealEls.forEach((el) => {
        const delay = parseInt(el.dataset.delay || '0') / 1000;
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 0.75,
          delay,
          ease: 'power3.out',
        });
      });
    },
  });
</script>