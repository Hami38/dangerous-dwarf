---
/* LinkedInButton.astro */
const { href = "https://pl.linkedin.com/in/kamil-wardak-760b6119b" } = Astro.props;
---

<div class="social-wrapper">
  <a href={href} target="_blank" class="social-link-linkedin" aria-label="LinkedIn">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
      <path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"></path>
    </svg>
  </a>
</div>

<style>
  .social-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    /* Dopasowane do wysokości headera, aby nie rozpychało paska */
    height: 40px; 
    width: 40px;
  }

  .social-link-linkedin {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: whitesmoke;
    text-decoration: none;
    transition: 0.25s;
    border-radius: 50%; /* Idealne koło */
    background-color: transparent; /* Startujemy bez tła */
  }

  .social-link-linkedin svg {
    width: 20px; /* Rozmiar ikony */
    height: 20px;
    fill: #fff;
    transition: transform 0.25s;
    z-index: 2;
  }

  /* Efekt Hover */
  .social-link-linkedin:hover {
    background-color: #0a66c2; /* Klasyczny niebieski LinkedIn */
    animation: bounce_613 0.4s linear;
  }

  /* Animacja Bounce */
  @keyframes bounce_613 {
    40% {
      transform: scale(1.4);
    }
    60% {
      transform: scale(0.8);
    }
    80% {
      transform: scale(1.2);
    }
    100% {
      transform: scale(1);
    }
  }
</style>