---
/* src/components/HeroExpandMobile.astro */
const staticPlaceholder = "/sequence/000001.jpg";

const stats = [
  {
    title: "Skala i Doświadczenie",
    heading: "12 lat w branży",
    description: "Projektowanie produktów dla sektorów finansowego, medycznego i zbrojeniowego."
  },
  {
    title: "Wynik i Satysfakcja (NPS)",
    heading: "NPS 45,9 w ING",
    description: "Osiągnięcie bardzo dobrego poziomu Customer Experience (CX) w wymagającym segmencie SME/MC."
  },
  {
    title: "Realny Wpływ Biznesowy",
    heading: "Mierzalne rezultaty",
    description: "Redukcja incydentów o 21% w systemach kolejowych i wzrost zainteresowania produktami HealthTech o 43%."
  },
  {
    title: "Innowacje i Strategia",
    heading: "AI & Leadership",
    description: "Wdrażanie asystentów GenAI oraz współtworzenie strategii w międzynarodowej gildii projektowej."
  }
];
---

<div class="mobile-expand block md:hidden">
  <div class="me-trigger">
    <div class="me-stage">
      <div class="me-inner">
        <img src={staticPlaceholder} class="me-static-img" alt="Kamil Wardak" />
        <canvas id="me-canvas" class="me-canvas opacity-0"></canvas>

        <div class="me-overlay opacity-0 pointer-events-none">
          <div class="me-cards-scroll">
            {stats.map((stat) => (
              <div class="me-stat-card">
                <div class="me-card-label">
                  <span class="reveal-block-el"></span>
                  <span class="me-label-text text-[#BAF52A] text-[10px] uppercase tracking-widest font-extrabold block">{stat.title}</span>
                </div>
                <div class="me-card-heading">
                  <span class="reveal-block-el"></span>
                  <h3 class="me-heading-text text-white text-xl font-bold">{stat.heading}</h3>
                </div>
                <div class="me-card-desc">
                  <span class="reveal-block-el"></span>
                  <p class="me-desc-text text-stone-300 text-xs leading-relaxed font-medium">{stat.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .me-trigger { position: relative; background: #0c0a09; }

  .me-stage {
    width: 100%; height: 100vh;
    background: #0c0a09; overflow: hidden;
  }

  .me-inner {
    width: 100%; height: 100%;
    position: relative; background: #000; overflow: hidden;
  }

  .me-static-img, .me-canvas {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center; display: block;
  }

  .me-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(12,10,9,0.4) 0%, rgba(12,10,9,0.92) 100%);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    padding: 1.5rem 0; z-index: 20;
  }

  .me-cards-scroll {
    width: 100%; max-height: 100%;
    overflow-y: auto;
    padding: 0 1.25rem;
    display: flex; flex-direction: column; gap: 0.75rem;
    scrollbar-width: none; -ms-overflow-style: none;
  }
  .me-cards-scroll::-webkit-scrollbar { display: none; }

  .me-stat-card {
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    padding: 1.25rem; border-radius: 1.25rem;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 15px 35px rgba(0,0,0,0.6);
    flex-shrink: 0;
    /* Kafel jako całość wjeżdża fade+up */
    opacity: 0; transform: translateY(16px);
    will-change: opacity, transform;
  }

  /* Wiersze tekstu — relative + overflow dla block reveal */
  .me-card-label,
  .me-card-heading,
  .me-card-desc {
    position: relative; overflow: hidden;
    display: block; margin-bottom: 0.35rem;
  }
  .me-card-desc { margin-bottom: 0; }

  /* Blok zasłaniający */
  .reveal-block-el {
    position: absolute; inset: 0;
    background: #BAF52A;
    transform: scaleX(0);
    transform-origin: left center;
    z-index: 2; display: block; pointer-events: none;
  }

  /* Teksty schowane przed animacją */
  .me-label-text,
  .me-heading-text,
  .me-desc-text {
    opacity: 0; display: block;
    position: relative; z-index: 1;
  }

  /* Kompaktowe kafle na małych ekranach */
  @media (max-height: 600px), (max-width: 380px) {
    .me-stat-card { padding: 0.875rem 1rem; border-radius: 1rem; }
    .me-stat-card h3 { font-size: 1rem; margin-bottom: 0.2rem; }
    .me-stat-card p  { font-size: 0.7rem; }
    .me-cards-scroll { gap: 0.5rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add("(max-width: 767px)", () => {
    const frameCount = 48;
    const framePath = (i: number) => `/sequence/${i.toString().padStart(6, '0')}.jpg`;

    const trigger   = document.querySelector('.me-trigger') as HTMLElement;
    const stage     = document.querySelector('.me-stage') as HTMLElement;
    const canvas    = document.getElementById('me-canvas') as HTMLCanvasElement;
    const staticImg = document.querySelector('.me-static-img') as HTMLImageElement;
    const overlay   = document.querySelector('.me-overlay') as HTMLElement;
    const statCards = document.querySelectorAll('.me-stat-card');

    if (!trigger || !stage || !canvas) return;

    const ctx = canvas.getContext('2d');
    const seq = { frame: 1 };
    const images: HTMLImageElement[] = [];
    let cW = 0, cH = 0;

    const cacheSize = () => {
      const dpr = window.devicePixelRatio || 1;
      cW = Math.round(canvas.offsetWidth * dpr);
      cH = Math.round(canvas.offsetHeight * dpr);
      canvas.width = cW;
      canvas.height = cH;
    };

    const render = () => {
      const img = images[seq.frame - 1];
      if (!img?.complete || !ctx || cW === 0) return;
      const ir = img.naturalWidth / img.naturalHeight;
      const cr = cW / cH;
      let dW, dH, dX, dY;
      if (ir > cr) { dH = cH; dW = cH * ir; dX = (cW - dW) / 2; dY = 0; }
      else         { dW = cW; dH = cW / ir; dX = 0; dY = (cH - dH) / 2; }
      ctx.clearRect(0, 0, cW, cH);
      ctx.imageSmoothingEnabled = true;
      ctx.imageSmoothingQuality = 'high';
      ctx.drawImage(img, dX, dY, dW, dH);
    };

    let loaded = 0;
    for (let i = 1; i <= frameCount; i++) {
      const img = new Image();
      img.src = framePath(i);
      img.onload = img.onerror = () => { if (++loaded === frameCount) buildTimeline(); };
      images.push(img);
    }

    /**
     * Block Reveal dla jednego kafla mobilnego.
     * Linie: label → heading → desc, każda odsłaniana osobno.
     */
    const buildCardReveal = (card: Element): gsap.core.Timeline => {
      const tl = gsap.timeline();
      const rows = card.querySelectorAll<HTMLElement>('.me-card-label, .me-card-heading, .me-card-desc');

      rows.forEach((row, i) => {
        const block = row.querySelector<HTMLElement>('.reveal-block-el');
        const text  = row.querySelector<HTMLElement>('.me-label-text, .me-heading-text, .me-desc-text');
        if (!block || !text) return;

        tl.to(block, {
          scaleX: 1, duration: 0.28,
          ease: 'power2.inOut', transformOrigin: 'left center',
        }, i * 0.08)
        .set(text, { opacity: 1 }, '>')
        .to(block, {
          scaleX: 0, duration: 0.28,
          ease: 'power2.inOut', transformOrigin: 'right center',
        });
      });

      return tl;
    };

    const buildTimeline = () => {
      cacheSize();
      render();

      const masterTL = gsap.timeline({
        scrollTrigger: {
          trigger: trigger,
          pin: stage,
          start: 'top top',
          end: '+=250%',
          scrub: 0.8,
          pinSpacing: true,
          anticipatePin: 1,
          invalidateOnRefresh: true,
        }
      });

      // Faza 1 — sekwencja klatek
      masterTL
        .set(canvas,    { opacity: 1 }, 0.05)
        .set(staticImg, { opacity: 0 }, 0.05)
        .to(seq, {
          frame: frameCount, snap: 'frame',
          duration: 2, ease: 'none', onUpdate: render,
        }, 0);

      // Faza 2 — overlay
      masterTL.to(overlay, {
        opacity: 1, duration: 0.8, ease: 'power2.out',
        onStart: () => { overlay.style.pointerEvents = 'auto'; },
      }, '>-0.2');

      // Faza 3 — kafle jako całość (fade+up)
      masterTL.to(statCards, {
        opacity: 1, y: 0,
        duration: 0.5, stagger: 0.15, ease: 'power3.out',
      }, '>-0.3');

      // Faza 4 — Block Reveal tekstu w każdym kaflu
      statCards.forEach((card) => {
        masterTL.add(buildCardReveal(card), '>-0.2');
      });

      // Faza 5 — zatrzymanie po ostatnim kaflu
      masterTL.to({}, { duration: 1.2 });

      window.addEventListener('resize', () => { cacheSize(); render(); ScrollTrigger.refresh(); });
      ScrollTrigger.refresh();
    };
  });
</script>