---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import Footer from '../../components/Footer.astro';

const project = {
  overline: "HealthTech / Senior Care / IoT",
  title: "TabBox — Ekosystem farmakoterapii",
  subtitle: "Zintegrowany system HW/SW dla osób z demencją: przeniesienie odpowiedzialności za terapię z pacjenta na technologię. 89% poprawa adherence, kontrakt na masową produkcję w 8 tygodniach od premiery.",
  role: "Strategic Product Lead / Creative Director",
  client: "TabBox",
  year: "2023",
  scope: "Industrial Design · Mobile UX · Service Design · IoT",
};

const challenges = [
  {
    number: "01",
    title: "Bariery motoryczno-sensoryczne",
    description: "Osoby z artretyzmem i ograniczonym chwytem pęsetowym nie mogły obsługiwać standardowych dozowników. Każda fizyczna interakcja z urządzeniem groziła wysypaniem leków lub całkowitym porzuceniem terapii.",
  },
  {
    number: "02",
    title: "Churn Point: żmudny onboarding",
    description: "Manualne wpisywanie nazw, dawek i harmonogramów leków było największym punktem porzucenia produktu. Złożone plany leczenia (leki stałe, suplementy, leki doraźne) generowały błędy i frustrację opiekunów.",
  },
  {
    number: "03",
    title: "Ciągłość opieki w czasie",
    description: "Opiekun nie miał wglądu w to, czy senior faktycznie wziął leki — bez angażowania go w raportowanie. System musiał monitorować zapasy i przerwanie terapii zanim do niego dojdzie.",
  },
];

const results = [
  { value: "89%", label: "aktywnych użytkowników potwierdza realną poprawę systematyczności przyjmowania leków" },
  { value: "5000+", label: "aktywnych użytkowników dołączyło do ekosystemu w zaledwie dwa miesiące od premiery" },
  { value: "-75%", label: "skrócenie czasu onboardingu leku dzięki modułowi OCR Scan & Add" },
  { value: "8 tyg.", label: "od rynkowej premiery do zabezpieczenia kontraktu na masową produkcję hardware" },
];

const nextProjects = [
  {
    overline: "Finanse / Strategia UX",
    title: "BLIK dla Biznesu w ING",
    description: "Adaptacja retailowych wzorców płatniczych do złożonego ekosystemu bankowości korporacyjnej.",
    href: "/projekty/blik-dla-biznesu",
    image: "/images/ing/KV_blik.webp",
  },
  {
    overline: "Bezpieczeństwo / Computer Vision",
    title: "System reidentyfikacji osób dla infrastruktury krytycznej",
    description: "Integracja zaawansowanego rzemiosła UX z systemami wizyjnymi AI. 20% ROI w 6 miesięcy.",
    href: "/projekty/reid",
    image: "/images/reid/hero_reid.webp",
  },
  {
    overline: "Bezpieczeństwo krytyczne / Deep Tech",
    title: "VTDA — Wirtualny Asystent Maszynisty",
    description: "Redukcja incydentów kolejowych o 20%. System wspomagania decyzji w czasie rzeczywistym.",
    href: "/projekty/vtda",
    image: "/images/vtda/VTDA_01.webp",
  },
];
---

<Layout title={`${project.title} | Kamil Wardak`}>

  <!-- ─── PRELOADER BYPASS ───────────────────────────────────────────────── -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        window.dispatchEvent(new CustomEvent('preloaderFinished'));
      }, 100);
    });
  </script>

  <div class="bg-[#0c0a09] min-h-screen">

    <!-- ─── SPACER pod header ──────────────────────────────────────────────── -->
    <div class="h-20"></div>

    <!-- ═══════════════════════════════════════════════════════════════════════
         HERO SECTION
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-hero relative px-6 pt-0 pb-0 md:pt-16 overflow-hidden">
      <div class="max-w-4xl mx-auto">

        <!-- Breadcrumb -->
        <div class="cs-breadcrumb mb-10 opacity-0" data-hero-fade style="--delay: 0s">
          <a href="/prace" class="cs-back-link group inline-flex items-center gap-2 text-white/40 text-sm font-medium transition-colors duration-300 hover:text-[#BAF52A]">
            <svg class="cs-back-arrow transition-transform duration-300 group-hover:-translate-x-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14m-7-7-7 7 7 7"/>
            </svg>
            <span>Wszystkie projekty</span>
          </a>
        </div>

        <!-- Overline label -->
        <div class="mb-5 opacity-0" data-hero-fade style="--delay: 0.05s">
          <Reveal trigger="onLoad" delay={0.15} color="#BAF52A">
            <p class="cs-overline text-[#BAF52A] text-xs tracking-[0.15em] font-bold">{project.overline}</p>
          </Reveal>
        </div>

        <!-- Main title -->
        <div class="mb-6">
          <Reveal trigger="onLoad" delay={0.3} duration={0.8} color="#ffffff">
            <h1 class="cs-hero-title text-white font-bold leading-[1.05] tracking-tight">
              {project.title}
            </h1>
          </Reveal>
        </div>

        <!-- Subtitle -->
        <div class="max-w-2xl mb-12">
          <Reveal trigger="onLoad" delay={0.55} color="#a8a29e">
            <p class="cs-hero-subtitle text-stone-400 text-lg md:text-xl font-medium leading-relaxed">
              {project.subtitle}
            </p>
          </Reveal>
        </div>

        <!-- Meta strip -->
        <div class="cs-meta-strip opacity-0" data-hero-fade style="--delay: 0.7s">
          <div class="cs-meta-item">
            <span class="cs-meta-label">Rola</span>
            <span class="cs-meta-value">{project.role}</span>
          </div>
          <div class="cs-meta-divider"></div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Klient</span>
            <span class="cs-meta-value">{project.client}</span>
          </div>
          <div class="cs-meta-divider"></div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Rok</span>
            <span class="cs-meta-value">{project.year}</span>
          </div>
          <div class="cs-meta-divider"></div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Zakres</span>
            <span class="cs-meta-value">{project.scope}</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── NOTA O PROJEKCIE ─────────────────────────────────────────────── -->
    <section class="px-6 pt-8 pb-0">
      <div class="max-w-4xl mx-auto">
        <div class="cs-confidentiality-note opacity-0" data-hero-fade style="--delay: 0.85s">
          <svg class="cs-conf-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <p>
            <strong>Nota o projekcie:</strong> TabBox to autorski produkt komercyjny klasy HealthTech. Case study koncentruje się na strategii produktowej, architekturze decyzji projektowych i mierzalnym wpływie na bezpieczeństwo farmakologiczne — na podstawie danych zebranych po rynkowej premierze.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── HERO IMAGE ─────────────────────────────────────────────────────── -->
    <section class="cs-hero-image-section px-6 pt-12 pb-0">
      <div class="max-w-4xl mx-auto">
        <div class="cs-hero-img-wrapper opacity-0" data-scroll-fade>
          <div class="aspect-[16/7] rounded-3xl overflow-hidden border border-white/5">
            <img src="/images/tabbox/KV_tabbox.webp" alt="TabBox — inteligentny ekosystem farmakoterapii dla seniorów" class="w-full h-full object-cover cs-img" loading="eager" />
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 1 — STRATEGIA
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section px-6 pt-28 md:pt-36 pb-0">
      <div class="max-w-4xl mx-auto">

        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">

          <!-- Left: Number + heading -->
          <div class="md:col-span-5">
            <Reveal delay={0.1} color="#BAF52A">
              <p class="cs-section-number">01</p>
            </Reveal>
            <Reveal delay={0.25} color="#ffffff">
              <h2 class="cs-section-heading mt-3">
                Strategia „Zero-Error Policy"
              </h2>
            </Reveal>
          </div>

          <!-- Right: Body text -->
          <div class="md:col-span-7">
            <Reveal delay={0.35} color="#a8a29e">
              <p class="cs-body-text mb-6">
                W systemach klasy Safety-Critical dla seniorów koszt błędu poznawczego jest zbyt wysoki, by polegać na standardowych wzorcach UX. Medication Non-Adherence — nieprzestrzeganie planu leczenia — jest jedną z głównych przyczyn hospitalizacji osób starszych.
              </p>
            </Reveal>
            <Reveal delay={0.5} color="#a8a29e">
              <p class="cs-body-text">
                Przyjąłem strategię przeniesienia odpowiedzialności za proces z użytkownika na technologię. Senior nie powinien być administratorem własnej terapii — powinien być pacjentem. Każda decyzja projektowa, zarówno w warstwie hardware jak i software, wynikała z tej jednej zasady.
              </p>
            </Reveal>
          </div>

        </div>

        <!-- Context images -->
        <div class="cs-img-wrapper mt-16 opacity-0" data-scroll-fade>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <figure class="m-0 p-0">
              <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/5">
                <img src="/images/tabbox/empathy_map_tabbox.webp" alt="Mapa empatii — perspektywa seniora i opiekuna" class="w-full h-full object-cover cs-img" loading="lazy" />
              </div>
              <figcaption class="cs-img-caption">Mapa empatii — perspektywa seniora i opiekuna</figcaption>
            </figure>
            <figure class="m-0 p-0">
              <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/5">
                <img src="/images/tabbox/edherence_tabbox.webp" alt="Analiza kontekstu — bariery Medication Non-Adherence" class="w-full h-full object-cover cs-img" loading="lazy" />
              </div>
              <figcaption class="cs-img-caption">Problems & Solutions — zestawienie barier i odpowiedzi projektowych</figcaption>
            </figure>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 2 — WYZWANIA
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section cs-section--dark px-6 pt-28 md:pt-36 pb-28 md:pb-36">
      <div class="max-w-4xl mx-auto">

        <!-- Section header -->
        <div class="mb-16 md:mb-20">
          <Reveal delay={0.1} color="#BAF52A">
            <p class="cs-section-number">02</p>
          </Reveal>
          <Reveal delay={0.25} color="#ffffff">
            <h2 class="cs-section-heading mt-3 max-w-xl">
              Trzy bariery do eliminacji
            </h2>
          </Reveal>
          <Reveal delay={0.4} color="#a8a29e">
            <p class="cs-body-text max-w-2xl mt-4">
              Projekt obejmował dwa produkty równolegle — fizyczne urządzenie i aplikację mobilną. Każdy z nich miał własne, krytyczne punkty niepowodzenia.
            </p>
          </Reveal>
        </div>

        <!-- Challenge cards -->
        <div class="cs-challenges-grid">
          {challenges.map((ch, i) => (
            <div class="cs-challenge-card opacity-0" data-scroll-fade style={`--fade-delay: ${0.1 + i * 0.15}s`}>
              <div class="cs-challenge-number">{ch.number}</div>
              <div class="cs-challenge-content">
                <h3 class="cs-challenge-title">{ch.title}</h3>
                <p class="cs-challenge-desc">{ch.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Wide context image -->
        <div class="mt-20 opacity-0" data-scroll-fade style="--fade-delay: 0.3s">
          <figure class="m-0 p-0">
            <div class="aspect-[21/9] rounded-3xl overflow-hidden border border-white/5">
              <img src="/images/tabbox/ujm_tabbox.webp" alt="User Journey Map — punkty tarcia na ścieżce seniora i opiekuna" class="w-full h-full object-cover cs-img" loading="lazy" />
            </div>
            <figcaption class="cs-img-caption">User Journey Map — punkty tarcia na ścieżce seniora i opiekuna</figcaption>
          </figure>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 3 — PODEJŚCIE PROJEKTOWE (HW + SW)
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section px-6 pt-28 md:pt-36 pb-0">
      <div class="max-w-4xl mx-auto">

        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">

          <!-- Left: Heading -->
          <div class="md:col-span-5 md:sticky md:top-28">
            <Reveal delay={0.1} color="#BAF52A">
              <p class="cs-section-number">03</p>
            </Reveal>
            <Reveal delay={0.25} color="#ffffff">
              <h2 class="cs-section-heading mt-3">
                Dwa produkty,&nbsp;jedna spójność
              </h2>
            </Reveal>
            <Reveal delay={0.4} color="#a8a29e">
              <p class="cs-body-text mt-4">
                Jednoczesne projektowanie hardware i software wymagało utrzymania spójności doświadczenia w obu warstwach — od mechaniki klapki po architekturę powiadomień.
              </p>
            </Reveal>

            <!-- HW/SW dual track badge -->
            <div class="cs-dual-track mt-6 opacity-0" data-scroll-fade style="--fade-delay: 0.5s">
              <div class="cs-dual-track-item">
                <div class="cs-dual-track-dot cs-dual-track-dot--hw"></div>
                <span>Hardware</span>
              </div>
              <div class="cs-dual-track-item">
                <div class="cs-dual-track-dot cs-dual-track-dot--sw"></div>
                <span>Software</span>
              </div>
            </div>
          </div>

          <!-- Right: Role items -->
          <div class="md:col-span-7 flex flex-col gap-10">

            <div class="cs-role-item opacity-0" data-scroll-fade style="--fade-delay: 0.1s">
              <div class="cs-role-tag cs-role-tag--hw">Evidence-Based Industrial Design</div>
              <p class="cs-body-text mt-3">
                Zrezygnowałem z typowych szufladek na rzecz autorskich przegród otwieranych klapką do góry. Konstrukcja zoptymalizowana pod kątem osób z artretyzmem — mechanizm umożliwia bezwysiłkowy dostęp bez ryzyka wysypania leków. Każde otwarcie klapki jest jednocześnie zdarzeniem cyfrowym rejestrowanym w aplikacji, zamykając pętlę informacyjną bez angażowania pacjenta w raportowanie.
              </p>
              <div class="mt-6 opacity-0" data-scroll-fade style="--fade-delay: 0.2s">
                <figure class="m-0 p-0">
                  <div class="aspect-[16/7] rounded-2xl overflow-hidden border border-white/5">
                    <img src="/images/tabbox/mechanizm_tabbox.webp" alt="Industrial Design — mechanizm klapki zoptymalizowany pod artretyzm" class="w-full h-full object-cover cs-img" loading="lazy" />
                  </div>
                  <figcaption class="cs-img-caption">Industrial Design — mechanizm klapki zoptymalizowany pod artretyzm</figcaption>
                </figure>
              </div>
            </div>

            <div class="cs-role-item opacity-0" data-scroll-fade style="--fade-delay: 0.2s">
              <div class="cs-role-tag cs-role-tag--sw">UX Architecture — Scan & Add (OCR)</div>
              <p class="cs-body-text mt-3">
                Zidentyfikowałem żmudną, manualną konfigurację planów leczenia jako główny Churn Point produktu. Rozbudowałem architekturę aplikacji o autorski moduł OCR: opiekun skanuje opakowanie leku, system automatycznie paruje dane z bazą produktów leczniczych, pobierając nazwę, dawkę, datę ważności i status refundacji. Wynik: skrócenie onboardingu o 75% i eliminacja błędów wynikających z ręcznego przepisywania.
              </p>
              <div class="mt-6 opacity-0" data-scroll-fade style="--fade-delay: 0.25s">
                <figure class="m-0 p-0">
                  <div class="aspect-[16/7] rounded-2xl overflow-hidden border border-white/5">
                    <img src="/images/tabbox/scan_tabbox.webp" alt="Scan & Add — flow skanowania opakowania i automatycznego onboardingu leku" class="w-full h-full object-cover cs-img" loading="lazy" />
                  </div>
                  <figcaption class="cs-img-caption">Scan & Add — widok ekranów procesu skanowania opakowania leku</figcaption>
                </figure>
              </div>
            </div>

            <div class="cs-role-item opacity-0" data-scroll-fade style="--fade-delay: 0.3s">
              <div class="cs-role-tag cs-role-tag--sw">Service Design — Zarządzanie zapasami</div>
              <p class="cs-body-text mt-3">
                Zaprojektowałem system zarządzania wieloma zmiennymi (leki stałe, suplementy, leki doraźne) zachowujący minimalizm poznawczy niezbędny w sytuacjach stresowych dla opiekuna. System w czasie rzeczywistym monitoruje fizyczny stan tabletek i generuje alerty o konieczności uzupełnienia — zapobiegając przerwaniu terapii zanim do niego dojdzie.
              </p>
            </div>

          </div>
        </div>

        <!-- Full-width app mockup -->
        <div class="mt-20 opacity-0" data-scroll-fade>
          <figure class="m-0 p-0">
            <div class="aspect-[16/8] rounded-3xl overflow-hidden border border-white/5">
              <img src="/images/tabbox/dashboard_tabbox.webp" alt="TabBox App — główny ekran dashboardu opiekuna" class="w-full h-full object-cover cs-img" loading="lazy" />
            </div>
            <figcaption class="cs-img-caption">TabBox App — główny ekran dashboardu opiekuna</figcaption>
          </figure>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 4 — EFEKTY I WPŁYW BIZNESOWY
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section cs-section--results px-6 pt-28 md:pt-36 pb-28 md:pb-36">
      <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="mb-16 md:mb-20">
          <Reveal delay={0.1} color="#BAF52A">
            <p class="cs-section-number">04</p>
          </Reveal>
          <Reveal delay={0.25} color="#ffffff">
            <h2 class="cs-section-heading mt-3">
              Walidacja rynkowa i&nbsp;impact
            </h2>
          </Reveal>
          <Reveal delay={0.4} color="#a8a29e">
            <p class="cs-body-text max-w-2xl mt-4">
              Inkluzywny design oparty na dowodach (Evidence-Based) okazał się silnym driverem wzrostu. Produkt przeszedł pełną walidację rynkową — od UX, przez hardware, po skalę biznesową.
            </p>
          </Reveal>
        </div>

        <!-- Results grid -->
        <div class="cs-results-grid">
          {results.map((r, i) => (
            <div class="cs-result-card opacity-0" data-scroll-fade style={`--fade-delay: ${0.1 + i * 0.12}s`}>
              <div class="cs-result-value">{r.value}</div>
              <p class="cs-result-label">{r.label}</p>
            </div>
          ))}
        </div>

        <!-- Quote -->
        <div class="mt-20 opacity-0" data-scroll-fade style="--fade-delay: 0.2s">
          <div class="cs-quote-block">
            <div class="cs-quote-line" aria-hidden="true"></div>
            <blockquote class="cs-quote-text">
              "Zamiast projektować kolejną aplikację z przypomnieniami, zbudowałem ekosystem, który przenosi odpowiedzialność za terapię z użytkownika na technologię — tak, żeby senior mógł być pacjentem, a nie administratorem własnego leczenia."
            </blockquote>
            <p class="cs-quote-source">Kamil Wardak · Strategic Product Lead / Creative Director, projekt TabBox</p>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         GALLERY STRIP
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-gallery-section px-6 pb-28 md:pb-36 overflow-hidden">
      <div class="max-w-4xl mx-auto">

        <div class="mb-12">
          <Reveal delay={0.1} color="#BAF52A">
            <p class="text-[#BAF52A] text-xs tracking-[0.15em] font-bold">Materiały wizualne</p>
          </Reveal>
          <Reveal delay={0.25} color="#ffffff">
            <h2 class="cs-gallery-heading mt-2">Dokumentacja procesu</h2>
          </Reveal>
        </div>

        <!-- Row 1: 1 wide + 1 narrow -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-5 mb-5 opacity-0" data-scroll-fade>
          <div class="md:col-span-8">
            <figure class="m-0 p-0">
              <div class="aspect-[16/9] rounded-2xl overflow-hidden border border-white/5">
                <img src="/images/tabbox/overview_tabbox.webp" alt="Overview ekosystemu TabBox — połączenie hardware i aplikacji mobilnej" class="w-full h-full object-cover cs-img" loading="lazy" />
              </div>
              <figcaption class="cs-img-caption">Overview ekosystemu — połączenie hardware i aplikacji mobilnej</figcaption>
            </figure>
          </div>
          <div class="md:col-span-4">
            <figure class="m-0 p-0">
              <div class="aspect-[16/9] rounded-2xl overflow-hidden border border-white/5">
                <img src="/images/tabbox/user_flow_tabbox.webp" alt="User flow — ścieżka onboardingu opiekuna" class="w-full h-full object-cover cs-img" loading="lazy" />
              </div>
              <figcaption class="cs-img-caption">User flow — ścieżka onboardingu opiekuna</figcaption>
            </figure>
          </div>
        </div>

        <!-- Row 2: 3 equal -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-5 opacity-0" data-scroll-fade style="--fade-delay: 0.15s">
          <figure class="m-0 p-0">
            <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/5">
