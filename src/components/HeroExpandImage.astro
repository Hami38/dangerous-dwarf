---
/* src/components/HeroExpandImage.astro */
const staticPlaceholder = "/sequence/000001.jpg";

const stats = [
  {
    title: "Skala i Doświadczenie",
    heading: "12 lat w branży",
    description: "Projektowanie produktów dla sektorów finansowego, medycznego i zbrojeniowego."
  },
  {
    title: "Wynik i Satysfakcja (NPS)",
    heading: "NPS 45,9 w ING",
    description: "Osiągnięcie bardzo dobrego poziomu Customer Experience (CX) w wymagającym segmencie SME/MC."
  },
  {
    title: "Realny Wpływ Biznesowy",
    heading: "Mierzalne rezultaty",
    description: "Redukcja incydentów o 21% w systemach kolejowych i wzrost zainteresowania produktami HealthTech o 43%."
  },
  {
    title: "Innowacje i Strategia",
    heading: "AI & Leadership",
    description: "Wdrażanie asystentów GenAI oraz współtworzenie strategii w międzynarodowej gildii projektowej."
  }
];
---

<div class="desktop-expand hidden md:block">
  <div class="de-trigger">
    <div class="de-stage">
      <div class="de-wrapper">
        <div class="de-inner">
          <div class="de-border"></div>

          <img src={staticPlaceholder} alt="Kamil Wardak" class="de-static-img" />
          <canvas id="de-canvas" class="de-canvas opacity-0"></canvas>

          <div class="de-overlay opacity-0 pointer-events-none">
            <div class="max-w-4xl mx-auto px-6 w-full grid grid-cols-2 gap-8">
              {stats.map((stat) => (
                <div class="de-stat-card">
                  <div class="de-card-text">
                    <div class="de-card-label">
                      {/* Blok w kolorze labelki — zielony #BAF52A */}
                      <span class="reveal-block-el reveal-block-label"></span>
                      <span class="de-label-text text-[#BAF52A] text-[12px] normalcase tracking-[0.2em] font-extrabold block">{stat.title}</span>
                    </div>
                    <div class="de-card-heading">
                      {/* Blok w kolorze headingu — biały */}
                      <span class="reveal-block-el reveal-block-heading"></span>
                      <h3 class="de-heading-text text-white text-3xl font-bold tracking-tight">{stat.heading}</h3>
                    </div>
                    <div class="de-card-desc">
                      {/* Blok w kolorze opisu — stone-300 */}
                      <span class="reveal-block-el reveal-block-desc"></span>
                      <p class="de-desc-text text-stone-300 text-sm leading-relaxed font-medium">{stat.description}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .de-trigger { position: relative; background: #0c0a09; }

  .de-stage {
    width: 100%; height: 100vh;
    display: flex; align-items: center; justify-content: center;
    background: #0c0a09; overflow: hidden;
  }

  .de-wrapper {
    max-width: 896px; width: 90%; aspect-ratio: 16 / 9;
    position: relative; z-index: 10;
    will-change: width, max-width, height;
  }

  .de-inner {
    width: 100%; height: 100%;
    border-radius: 32px; background: #000;
    position: relative; overflow: hidden;
    will-change: border-radius;
  }

  .de-border {
    position: absolute; inset: 0;
    border: 1px solid rgba(186,245,42,0.15);
    z-index: 5; border-radius: 32px;
    pointer-events: none; will-change: border-radius;
  }

  .de-static-img, .de-canvas {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center; display: block;
  }

  .de-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(12,10,9,0.3) 0%, rgba(12,10,9,0.9) 100%);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    display: flex; align-items: center; z-index: 20;
  }

  .de-stat-card {
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    padding: 2.25rem; border-radius: 2rem;
    border: none;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    position: relative; isolation: isolate;
    opacity: 0; transform: translateY(28px);
    will-change: opacity, transform;
  }

  /* Statyczny border bazowy */
  .de-stat-card::after {
    content: '';
    position: absolute; inset: 0;
    border-radius: inherit;
    border: 1px solid rgba(255,255,255,0.08);
    pointer-events: none;
    z-index: 1;
  }

  /* Świecący border — gradient przez --glow-angle, domyślnie niewidoczny */
  .de-stat-card::before {
    content: '';
    position: absolute; inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: conic-gradient(
      from var(--glow-angle, 0deg) at center,
      transparent 0%,
      #BAF52A 15%,
      #ffffff 30%,
      #a8a29e 45%,
      transparent 60%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 2;
    /* Poświata — rozmyty duplikat bordera świeci na zewnątrz kafla */
    filter: drop-shadow(0 0 6px #BAF52A) drop-shadow(0 0 18px rgba(186,245,42,0.5));
  }

  .de-stat-card.glow-active::before {
    opacity: var(--glow-opacity, 0);
  }

  /* Każda linia tekstu — pozycja relative żeby reveal-block był over nią */
  .de-card-label,
  .de-card-heading,
  .de-card-desc {
    position: relative;
    overflow: hidden;
    display: block;
    margin-bottom: 0.5rem;
  }
  .de-card-desc { margin-bottom: 0; }

  /* Bloki zasłaniające — każdy w kolorze swojego tekstu */
  .reveal-block-el {
    position: absolute; inset: 0;
    transform: scaleX(0);
    transform-origin: left center;
    z-index: 2; display: block; pointer-events: none;
  }
  .reveal-block-label   { background: #BAF52A; }           /* zielony — kolor labela */
  .reveal-block-heading { background: #ffffff; }           /* biały — kolor headingu */
  .reveal-block-desc    { background: #a8a29e; }

  /* Teksty schowane przed animacją */
  .de-label-text,
  .de-heading-text,
  .de-desc-text {
    opacity: 0;
    display: block;
    position: relative;
    z-index: 1;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add("(min-width: 768px)", () => {
    const frameCount = 48;
    const framePath = (i: number) => `/sequence/${i.toString().padStart(6, '0')}.jpg`;

    const trigger   = document.querySelector('.de-trigger') as HTMLElement;
    const stage     = document.querySelector('.de-stage') as HTMLElement;
    const wrapper   = document.querySelector('.de-wrapper') as HTMLElement;
    const inner     = document.querySelector('.de-inner') as HTMLElement;
    const border    = document.querySelector('.de-border') as HTMLElement;
    const canvas    = document.getElementById('de-canvas') as HTMLCanvasElement;
    const staticImg = document.querySelector('.de-static-img') as HTMLImageElement;
    const overlay   = document.querySelector('.de-overlay') as HTMLElement;
    const statCards = document.querySelectorAll('.de-stat-card');

    if (!trigger || !stage || !canvas) return;

    const ctx = canvas.getContext('2d');
    const seq = { frame: 1 };
    const images: HTMLImageElement[] = [];
    let cW = 0, cH = 0;

    const cacheSize = () => {
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      cW = Math.round(rect.width * dpr);
      cH = Math.round(rect.height * dpr);
      canvas.width = cW;
      canvas.height = cH;
    };

    const render = () => {
      const img = images[seq.frame - 1];
      if (!img?.complete || !ctx || cW === 0) return;
      const ir = img.naturalWidth / img.naturalHeight;
      const cr = cW / cH;
      let dW, dH, dX, dY;
      if (ir > cr) { dH = cH; dW = cH * ir; dX = (cW - dW) / 2; dY = 0; }
      else         { dW = cW; dH = cW / ir; dX = 0; dY = (cH - dH) / 2; }
      ctx.clearRect(0, 0, cW, cH);
      ctx.imageSmoothingEnabled = true;
      ctx.imageSmoothingQuality = 'high';
      ctx.drawImage(img, dX, dY, dW, dH);
    };

    let loaded = 0;
    for (let i = 1; i <= frameCount; i++) {
      const img = new Image();
      img.src = framePath(i);
      img.onload = img.onerror = () => { if (++loaded === frameCount) buildTimeline(); };
      images.push(img);
    }

    /**
     * Buduje sekwencję Block Reveal dla jednego kafla.
     * Każda linia (label → heading → desc) jest odsłaniana blokiem osobno.
     * Zwraca GSAP timeline gotowy do wstawienia do masterTL w odpowiednim miejscu.
     */
    const buildCardReveal = (card: Element): gsap.core.Timeline => {
      const tl = gsap.timeline();
      const rows = card.querySelectorAll<HTMLElement>('.de-card-label, .de-card-heading, .de-card-desc');

      rows.forEach((row, i) => {
        const block = row.querySelector<HTMLElement>('.reveal-block-el');
        const text  = row.querySelector<HTMLElement>('.de-label-text, .de-heading-text, .de-desc-text');
        if (!block || !text) return;

        tl.to(block, {
          scaleX: 1,
          duration: 0.35,
          ease: 'power2.inOut',
          transformOrigin: 'left center',
        }, i * 0.1)                         // linie startują z małym staggerem
        .set(text, { opacity: 1 }, '>')
        .to(block, {
          scaleX: 0,
          duration: 0.35,
          ease: 'power2.inOut',
          transformOrigin: 'right center',
        });
      });

      return tl;
    };

    const buildTimeline = () => {
      cacheSize();
      render();

      const masterTL = gsap.timeline({
        scrollTrigger: {
          trigger: trigger,
          pin: stage,
          start: 'top top',
          end: '+=300%',
          scrub: 1,
          pinSpacing: true,
          anticipatePin: 1,
          invalidateOnRefresh: true,
        }
      });

      // Faza 1 — obrazek rośnie
      masterTL
        .to(wrapper, {
          maxWidth: '100vw', width: '100vw',
          aspectRatio: 'unset', height: '100vh',
          duration: 2, ease: 'power2.inOut',
        }, 0)
        .to([inner, border], {
          borderRadius: 0, duration: 2, ease: 'power2.inOut',
        }, 0);

      // Faza 2 — sekwencja klatek
      masterTL
        .set(canvas,    { opacity: 1 }, 0.8)
        .set(staticImg, { opacity: 0 }, 0.8)
        .to(seq, {
          frame: frameCount, snap: 'frame',
          duration: 3, ease: 'none', onUpdate: render,
        }, 0.5);

      // Faza 3 — overlay pojawia się
      masterTL.to(overlay, {
        opacity: 1, duration: 1, ease: 'power2.out',
        onStart: () => { overlay.style.pointerEvents = 'auto'; },
      }, '>-0.5');

      // Faza 4 — kafle wjeżdżają jako całość (fade+up)
      masterTL.to(statCards, {
        opacity: 1, y: 0,
        duration: 0.7, stagger: 0.15, ease: 'power3.out',
      }, '>-0.3');

      // Faza 5 — Block Reveal tekstu w każdym kaflu, jeden po drugim
      statCards.forEach((card, i) => {
        masterTL.add(buildCardReveal(card), `>-0.3`);
      });

      // Faza 6 — chwila zatrzymania zanim scroll puści
      masterTL.to({}, { duration: 1.5 });

      window.addEventListener('resize', () => { cacheSize(); render(); ScrollTrigger.refresh(); });
      ScrollTrigger.refresh();

      // ── Border Glow na kaflach ────────────────────────────────────────────
      const EDGE_SENS = 30;

      const getProximity = (el: HTMLElement, x: number, y: number): number => {
        const {width, height} = el.getBoundingClientRect();
        const cx = width/2, cy = height/2;
        const kx = x-cx !== 0 ? cx/Math.abs(x-cx) : Infinity;
        const ky = y-cy !== 0 ? cy/Math.abs(y-cy) : Infinity;
        return Math.min(Math.max(1/Math.min(kx,ky), 0), 1);
      };

      const getAngle = (el: HTMLElement, x: number, y: number): number => {
        const {width, height} = el.getBoundingClientRect();
        const dx = x-width/2, dy = y-height/2;
        if (!dx && !dy) return 0;
        let deg = Math.atan2(dy,dx)*180/Math.PI+90;
        return deg < 0 ? deg+360 : deg;
      };

      document.querySelectorAll<HTMLElement>('.de-stat-card').forEach(card => {
        card.addEventListener('pointermove', (e: PointerEvent) => {
          const r = card.getBoundingClientRect();
          const x = e.clientX-r.left, y = e.clientY-r.top;
          const prox = getProximity(card, x, y);
          const opacity = Math.max(0, (prox*100-EDGE_SENS)/(100-EDGE_SENS));
          card.style.setProperty('--glow-angle', getAngle(card,x,y).toFixed(1)+'deg');
          card.style.setProperty('--glow-opacity', opacity.toFixed(3));
          card.classList.add('glow-active');
        });
        card.addEventListener('pointerleave', () => {
          card.style.setProperty('--glow-opacity', '0');
        });
      });
      // ─────────────────────────────────────────────────────────────────────
    };
  });
</script>