<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ─── Hero fade-in elements ─────────────────────────────────────────────────
  const heroFadeEls = document.querySelectorAll<HTMLElement>('[data-hero-fade]');
  heroFadeEls.forEach((el) => {
    const delay = parseFloat(getComputedStyle(el).getPropertyValue('--delay') || '0');
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.7,
      delay: 0.2 + delay,
      ease: 'power3.out',
    });
  });

  // ─── Scroll-triggered fade-in ──────────────────────────────────────────────
  const scrollFadeEls = document.querySelectorAll<HTMLElement>('[data-scroll-fade]');

  const scrollObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseFloat(
            getComputedStyle(el).getPropertyValue('--fade-delay') || '0'
          );
          setTimeout(() => {
            el.classList.add('in-view');
          }, delay * 1000);
          scrollObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -5% 0px' }
  );

  scrollFadeEls.forEach((el) => scrollObserver.observe(el));

  // ─── Challenge & result cards individual stagger ───────────────────────────
  const cardObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const parent = entry.target;
          const cards = parent.querySelectorAll<HTMLElement>('.cs-challenge-card, .cs-result-card, .cs-next-card');
          cards.forEach((card, i) => {
            gsap.to(card, {
              opacity: 1,
              y: 0,
              duration: 0.65,
              delay: 0.08 * i,
              ease: 'power3.out',
            });
          });
          cardObserver.unobserve(parent);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.cs-challenges-grid, .cs-results-grid, .cs-next-grid').forEach((grid) => {
    cardObserver.observe(grid);
  });

  // ─── Image zoom hints ──────────────────────────────────────────────────────
  const zoomHintSVG = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35M11 8v6M8 11h6"/></svg>`;

  document.querySelectorAll<HTMLElement>('.cs-img').forEach((img) => {
    const wrapper = img.parentElement as HTMLElement;
    wrapper.classList.add('cs-img-wrap');
    const hint = document.createElement('div');
    hint.className = 'cs-img-hint';
    hint.innerHTML = zoomHintSVG;
    hint.setAttribute('aria-hidden', 'true');
    wrapper.appendChild(hint);
  });

  // ─── Lightbox ──────────────────────────────────────────────────────────────
  const lightbox   = document.getElementById('cs-lightbox') as HTMLElement;
  const lbImg      = document.getElementById('cs-lb-img') as HTMLImageElement;
  const lbClose    = lightbox.querySelector<HTMLElement>('.cs-lb-close')!;
  const lbBackdrop = lightbox.querySelector<HTMLElement>('.cs-lb-backdrop')!;

  function openLightbox(src: string, alt: string) {
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.classList.add('cs-lb-open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('cs-lb-open');
    document.body.style.removeProperty('overflow');
    setTimeout(() => { lbImg.src = ''; }, 380);
  }

  document.querySelectorAll<HTMLElement>('.cs-img-wrap').forEach((wrap) => {
    wrap.addEventListener('click', () => {
      const img = wrap.querySelector<HTMLImageElement>('.cs-img');
      if (img) openLightbox(img.src, img.alt);
    });
  });

  lbClose.addEventListener('click', closeLightbox);
  lbBackdrop.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.classList.contains('cs-lb-open')) closeLightbox();
  });
</script>
