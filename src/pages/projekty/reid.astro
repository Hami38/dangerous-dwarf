---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import Footer from '../../components/Footer.astro';

const project = {
  overline: "Bezpieczeństwo / Computer Vision",
  title: "System reidentyfikacji osób dla infrastruktury krytycznej",
  subtitle: "Strategiczne zarządzanie złożonością w systemach AI: Od mapowania empatii operatora do 20% ROI w 6 miesiącach.",
  role: "Lead Product Designer / Strategic Architect",
  client: "New Security Systems",
  year: "2023",
  scope: "Product Design · AI/UX Strategy · Ethics & GDPR",
};

const challenges = [
  {
    number: "01",
    title: "Prywatność i etyka",
    description: "Jak zbudować zaufanie do technologii śledzenia biometrycznego? Wdrożenie w infrastrukturze krytycznej wymagało 100% zgodności z GDPR/CCPA i projektowania etyki jako przewagi — nie bariery.",
  },
  {
    number: "02",
    title: "Precyzja identyfikacji",
    description: "Jak wyeliminować false positives w systemie obsługującym 500 tys. kamer? Błędy identyfikacji generują ryzyko prawne i operacyjne — projektowanie musiało wzmacniać, nie zastępować osąd człowieka.",
  },
  {
    number: "03",
    title: "Cognitive Load operatora",
    description: "Jak obsłużyć setki strumieni wideo bez przeciążenia poznawczego? System musiał hierarchizować zdarzenia i dostarczać tylko te informacje, które wymagają interwencji — w odpowiednim czasie.",
  },
];

const results = [
  { value: "20% ROI", label: "zwrotu z inwestycji w pierwszym półroczu po wdrożeniu" },
  { value: "50+", label: "lokalizacji wdrożonych w zaledwie 60 dni od startu" },
  { value: "97%", label: "operatorów zaufało nowej metodzie identyfikacji biometrycznej" },
  { value: "32 sprinty", label: "180 dni iteracji z Design System bez długu projektowego" },
];

const nextProjects = [
  {
    overline: "Finanse / Strategia UX",
    title: "BLIK dla Biznesu w ING",
    description: "Adaptacja retailowych wzorców płatniczych do złożonego ekosystemu bankowości korporacyjnej.",
    href: "/projekty/blik-dla-biznesu",
    image: "/images/ing/KV_blik.webp",
  },
  {
    overline: "Bezpieczeństwo krytyczne / Deep Tech",
    title: "Wirtualny asystent dla maszynistów",
    description: "Redukcja incydentów kolejowych o 21%. System wspomagania decyzji w czasie rzeczywistym.",
    href: "#case-railway-ai",
  },
  {
    overline: "MedTech / IoT / Product Design",
    title: "Tabbox: Inteligentny system farmakoterapii",
    description: "Ekosystem łączący fizyczny dozownik leków z aplikacją mobilną.",
    href: "#case-healthtech",
  },
];
---

<Layout title={`${project.title} | Kamil Wardak`}>

  <!-- ─── PRELOADER BYPASS ───────────────────────────────────────────────── -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        window.dispatchEvent(new CustomEvent('preloaderFinished'));
      }, 100);
    });
  </script>

  <div class="bg-[#0c0a09] min-h-screen">

    <!-- ─── SPACER pod header ──────────────────────────────────────────────── -->
    <div class="h-20"></div>

    <!-- ═══════════════════════════════════════════════════════════════════════
         HERO SECTION
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-hero relative px-6 pt-0 pb-0 md:pt-16 overflow-hidden">
      <div class="max-w-4xl mx-auto">

        <!-- Breadcrumb -->
        <div class="cs-breadcrumb mb-10 opacity-0" data-hero-fade style="--delay: 0s">
          <a href="/prace" class="cs-back-link group inline-flex items-center gap-2 text-white/40 text-sm font-medium transition-colors duration-300 hover:text-[#BAF52A]">
            <svg class="cs-back-arrow transition-transform duration-300 group-hover:-translate-x-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14m-7-7-7 7 7 7"/>
            </svg>
            <span>Wszystkie projekty</span>
          </a>
        </div>

        <!-- Overline label -->
        <div class="mb-5 opacity-0" data-hero-fade style="--delay: 0.05s">
          <Reveal trigger="onLoad" delay={0.15} color="#BAF52A">
            <p class="cs-overline text-[#BAF52A] text-xs tracking-[0.15em] font-bold">{project.overline}</p>
          </Reveal>
        </div>

        <!-- Main title -->
        <div class="mb-6">
          <Reveal trigger="onLoad" delay={0.3} duration={0.8} color="#ffffff">
            <h1 class="cs-hero-title text-white font-bold leading-[1.05] tracking-tight">
              {project.title}
            </h1>
          </Reveal>
        </div>

        <!-- Subtitle -->
        <div class="max-w-2xl mb-12">
          <Reveal trigger="onLoad" delay={0.55} color="#a8a29e">
            <p class="cs-hero-subtitle text-stone-400 text-lg md:text-xl font-medium leading-relaxed">
              {project.subtitle}
            </p>
          </Reveal>
        </div>

        <!-- Meta strip -->
        <div class="cs-meta-strip opacity-0" data-hero-fade style="--delay: 0.7s">
          <div class="cs-meta-item">
            <span class="cs-meta-label">Rola</span>
            <span class="cs-meta-value">{project.role}</span>
          </div>
          <div class="cs-meta-divider"></div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Klient</span>
            <span class="cs-meta-value">{project.client}</span>
          </div>
          <div class="cs-meta-divider"></div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Rok</span>
            <span class="cs-meta-value">{project.year}</span>
          </div>
          <div class="cs-meta-divider"></div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Zakres</span>
            <span class="cs-meta-value">{project.scope}</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── NOTA O POUFNOŚCI ─────────────────────────────────────────────── -->
    <section class="px-6 pt-8 pb-0">
      <div class="max-w-4xl mx-auto">
        <div class="cs-confidentiality-note opacity-0" data-hero-fade style="--delay: 0.85s">
          <svg class="cs-conf-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <p>
            <strong>Nota o poufności:</strong> Ze względu na wrażliwy charakter danych biometrycznych, wizualizacje zostały zanonimizowane. Niniejsze case study koncentruje się na przywództwie projektowym, architekturze decyzji UX i mierzalnym wpływie biznesowym — nie na finalnych, produkcyjnych detalach interfejsu.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── HERO IMAGE ─────────────────────────────────────────────────────── -->
    <section class="cs-hero-image-section px-6 pt-12 pb-0">
      <div class="max-w-4xl mx-auto">
        <div class="cs-hero-img-wrapper opacity-0" data-scroll-fade>
          <div class="aspect-[16/7] rounded-3xl overflow-hidden border border-white/5 cs-placeholder cs-placeholder--hero">
            <div class="cs-placeholder-inner">
              <div class="cs-placeholder-icon">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="8" r="3"/><path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>
                  <path d="M17 8a5 5 0 1 1-10 0"/>
                  <circle cx="19" cy="6" r="2" fill="currentColor" opacity="0.4"/>
                  <circle cx="5" cy="6" r="2" fill="currentColor" opacity="0.4"/>
                </svg>
              </div>
              <p class="cs-placeholder-label">ReID Dashboard — Streamwall Interface</p>
              <p class="cs-placeholder-note">Wizualizacja zanonimizowana ze względu na poufność projektu</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 1 — KONTEKST
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section px-6 pt-28 md:pt-36 pb-0">
      <div class="max-w-4xl mx-auto">

        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">

          <!-- Left: Number + heading -->
          <div class="md:col-span-5">
            <Reveal delay={0.1} color="#BAF52A">
              <p class="cs-section-number">01</p>
            </Reveal>
            <Reveal delay={0.25} color="#ffffff">
              <h2 class="cs-section-heading mt-3">
                Komercjalizacja technologii głębokiego uczenia
              </h2>
            </Reveal>
          </div>

          <!-- Right: Body text -->
          <div class="md:col-span-7">
            <Reveal delay={0.35} color="#a8a29e">
              <p class="cs-body-text mb-6">
                Zadaniem było przekształcenie zaawansowanych algorytmów reidentyfikacji (Face, Gait, Cloth) w stabilny produkt klasy SaaS. Technologia istniała — brakowało warstwy, która uczyni ją używalną przez człowieka pod presją.
              </p>
            </Reveal>
            <Reveal delay={0.5} color="#a8a29e">
              <p class="cs-body-text">
                Kluczowym wyzwaniem nie była sama technologia Deep Learning, lecz projektowanie interfejsu minimalizującego Cognitive Overload operatorów monitoringu — przy zachowaniu 100% zgodności z normami etycznymi i prawnymi (GDPR/CCPA).
              </p>
            </Reveal>
          </div>

        </div>

        <!-- Context images -->
        <div class="cs-img-wrapper mt-16 opacity-0" data-scroll-fade>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <figure class="m-0 p-0">
              <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/5">
                <img src="/images/reid/empathy_map_reid.webp" alt="Empathy Map — persona operatora Jack i krytyczne napięcia" class="w-full h-full object-cover cs-img" loading="lazy" />
              </div>
              <figcaption class="cs-img-caption">Empathy Map — persona operatora "Jack" i krytyczne napięcia</figcaption>
            </figure>
            <figure class="m-0 p-0">
              <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/5 cs-placeholder">
                <div class="cs-placeholder-inner">
                  <div class="cs-placeholder-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                  </div>
                  <p class="cs-placeholder-label cs-placeholder-label--sm">Mapa ryzyka — Privacy · Accuracy · Cognitive Load</p>
                </div>
              </div>
              <figcaption class="cs-img-caption">Trójkąt ryzyka — balansowanie między prywatnością, precyzją i wydajnością</figcaption>
            </figure>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 2 — WYZWANIA
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section cs-section--dark px-6 pt-28 md:pt-36 pb-28 md:pb-36">
      <div class="max-w-4xl mx-auto">

        <!-- Section header -->
        <div class="mb-16 md:mb-20">
          <Reveal delay={0.1} color="#BAF52A">
            <p class="cs-section-number">02</p>
          </Reveal>
          <Reveal delay={0.25} color="#ffffff">
            <h2 class="cs-section-heading mt-3 max-w-xl">
              Design jako zarządzanie ryzykiem
            </h2>
          </Reveal>
          <Reveal delay={0.4} color="#a8a29e">
            <p class="cs-body-text max-w-2xl mt-4">
              Wdrożenie biometrii w infrastrukturze krytycznej wymagało wyważenia trzech sił. Każda z nich mogła samodzielnie zdyskredytować produkt na rynku.
            </p>
          </Reveal>
        </div>

        <!-- Challenge cards -->
        <div class="cs-challenges-grid">
          {challenges.map((ch, i) => (
            <div class="cs-challenge-card opacity-0" data-scroll-fade style={`--fade-delay: ${0.1 + i * 0.15}s`}>
              <div class="cs-challenge-number">{ch.number}</div>
              <div class="cs-challenge-content">
                <h3 class="cs-challenge-title">{ch.title}</h3>
                <p class="cs-challenge-desc">{ch.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Flow diagram placeholder -->
        <div class="mt-20 opacity-0" data-scroll-fade style="--fade-delay: 0.3s">
          <figure class="m-0 p-0">
            <div class="aspect-[21/9] rounded-3xl overflow-hidden border border-white/5 cs-placeholder">
              <div class="cs-placeholder-inner">
                <div class="cs-placeholder-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="4" height="4" rx="1"/><rect x="10" y="3" width="4" height="4" rx="1"/><rect x="17" y="3" width="4" height="4" rx="1"/>
                    <rect x="3" y="10" width="4" height="4" rx="1"/><rect x="10" y="10" width="4" height="4" rx="1"/><rect x="17" y="10" width="4" height="4" rx="1"/>
                    <rect x="3" y="17" width="4" height="4" rx="1"/><rect x="10" y="17" width="4" height="4" rx="1"/><rect x="17" y="17" width="4" height="4" rx="1"/>
                  </svg>
                </div>
                <p class="cs-placeholder-label">User Flow — od detekcji Gait Analysis po akcję interwencyjną</p>
                <p class="cs-placeholder-note">Pełny schemat ścieżek operatora — zanonimizowany</p>
              </div>
            </div>
            <figcaption class="cs-img-caption">User Flow — ścieżki od detekcji (Gait Analysis) po akcję interwencyjną operatora</figcaption>
          </figure>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 3 — MOJA ROLA
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section px-6 pt-28 md:pt-36 pb-0">
      <div class="max-w-4xl mx-auto">

        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">

          <!-- Left: Heading -->
          <div class="md:col-span-5 md:sticky md:top-28">
            <Reveal delay={0.1} color="#BAF52A">
              <p class="cs-section-number">03</p>
            </Reveal>
            <Reveal delay={0.25} color="#ffffff">
              <h2 class="cs-section-heading mt-3">
                Architektura produktu i&nbsp;podejście strategiczne
              </h2>
            </Reveal>
            <Reveal delay={0.4} color="#a8a29e">
              <p class="cs-body-text mt-4">
                180 dni iteracji w 32 sprintach. Zamiast budować system „dla wszystkich", skupiłem się na personie operatora i jego krytycznych napięciach.
              </p>
            </Reveal>
          </div>

          <!-- Right: Role items -->
          <div class="md:col-span-7 flex flex-col gap-10">

            <div class="cs-role-item opacity-0" data-scroll-fade style="--fade-delay: 0.1s">
              <div class="cs-role-tag">Empathy Mapping & Human-in-the-Loop</div>
              <p class="cs-body-text mt-3">
                Empathy Map ujawniła krytyczne napięcie: strach operatora przed odpowiedzialnością za błąd AI vs. potrzeba wydajności. Odpowiedzią był mechanizm Human-in-the-loop — AI sugeruje, człowiek zatwierdza. Decyzja ta zbudowała zaufanie użytkowników i ograniczyła ryzyko prawne.
              </p>
              <div class="mt-6 opacity-0" data-scroll-fade style="--fade-delay: 0.2s">
                <figure class="m-0 p-0">
                  <div class="aspect-[16/7] rounded-2xl overflow-hidden border border-white/5">
                    <img src="/images/reid/empathy_map_reid.webp" alt="Empathy Map — persona operatora, decyzja o Human-in-the-loop" class="w-full h-full object-cover cs-img" loading="lazy" />
                  </div>
                  <figcaption class="cs-img-caption">Empathy Map — persona operatora, decyzja o Human-in-the-loop</figcaption>
                </figure>
              </div>
            </div>

            <div class="cs-role-item opacity-0" data-scroll-fade style="--fade-delay: 0.2s">
              <div class="cs-role-tag">Architektura Streamwall</div>
              <p class="cs-body-text mt-3">
                Zaprojektowałem centralny dashboard zarządzający wieloma strumieniami wideo z inteligentną hierarchią wizualną. Streamwall promuje najważniejsze zdarzenia operacyjne — operator widzi dokładnie to, co wymaga uwagi, w precyzyjnym momencie.
              </p>
              <div class="mt-6 opacity-0" data-scroll-fade style="--fade-delay: 0.25s">
                <figure class="m-0 p-0">
                  <div class="aspect-[16/7] rounded-2xl overflow-hidden border border-white/5">
                    <img src="/images/reid/streamwall_reid.webp" alt="Dashboard Streamwall — inteligentna hierarchia wizualna, 500k+ kamer" class="w-full h-full object-cover cs-img" loading="lazy" />
                  </div>
                  <figcaption class="cs-img-caption">Dashboard Streamwall — inteligentna hierarchia wizualna, 500k+ kamer</figcaption>
                </figure>
              </div>
            </div>

            <div class="cs-role-item opacity-0" data-scroll-fade style="--fade-delay: 0.3s">
              <div class="cs-role-tag">Design System & Skalowanie</div>
              <p class="cs-body-text mt-3">
                Wdrożyłem Design System, który umożliwił szybkie skalowanie produktu na 50+ lokalizacji bez długu projektowego. Spójność komponentów pozwoliła zespołowi deweloperów na wdrożenie w 60 dni — znacznie poniżej zakładanego harmonogramu.
              </p>
            </div>

          </div>
        </div>

        <!-- Full-width mockup placeholder -->
        <div class="mt-20 opacity-0" data-scroll-fade>
          <figure class="m-0 p-0">
            <div class="aspect-[16/8] rounded-3xl overflow-hidden border border-white/5">
              <img src="/images/reid/streamwall_reid.webp" alt="Explore Dashboard — Gait Analysis jako główny atrybut reidentyfikacji, pełna diagnostyka kamer" class="w-full h-full object-cover cs-img" loading="lazy" />
            </div>
            <figcaption class="cs-img-caption">Explore Dashboard — Gait Analysis jako główny atrybut reidentyfikacji, pełna diagnostyka kamer</figcaption>
          </figure>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 4 — EFEKTY I WPŁYW BIZNESOWY
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section cs-section--results px-6 pt-28 md:pt-36 pb-28 md:pb-36">
      <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="mb-16 md:mb-20">
          <Reveal delay={0.1} color="#BAF52A">
            <p class="cs-section-number">04</p>
          </Reveal>
          <Reveal delay={0.25} color="#ffffff">
            <h2 class="cs-section-heading mt-3">
              Wyniki mierzone danymi
            </h2>
          </Reveal>
          <Reveal delay={0.4} color="#a8a29e">
            <p class="cs-body-text max-w-2xl mt-4">
              Decyzje projektowe bezpośrednio przełożyły się na sukces komercyjny. W sektorze bezpieczeństwa, gdzie zaufanie do nowej technologii buduje się latami — wyniki w 6 miesięcy to wyjątek, nie reguła.
            </p>
          </Reveal>
        </div>

        <!-- Results grid -->
        <div class="cs-results-grid">
          {results.map((r, i) => (
            <div class="cs-result-card opacity-0" data-scroll-fade style={`--fade-delay: ${0.1 + i * 0.12}s`}>
              <div class="cs-result-value">{r.value}</div>
              <p class="cs-result-label">{r.label}</p>
            </div>
          ))}
        </div>

        <!-- Quote / highlight -->
        <div class="mt-20 opacity-0" data-scroll-fade style="--fade-delay: 0.2s">
          <div class="cs-quote-block">
            <div class="cs-quote-line" aria-hidden="true"></div>
            <blockquote class="cs-quote-text">
              "Zamiast budować system dla wszystkich, skupiłem się na personie operatora. Empathy Map ujawniła krytyczne napięcie — i właśnie z niego zrodziło się rozwiązanie, które zbudowało zaufanie użytkowników."
            </blockquote>
            <p class="cs-quote-source">Kamil Wardak · Lead Product Designer, projekt ReID</p>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         GALLERY STRIP
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-gallery-section px-6 pb-28 md:pb-36 overflow-hidden">
      <div class="max-w-4xl mx-auto">

        <div class="mb-12">
          <Reveal delay={0.1} color="#BAF52A">
            <p class="text-[#BAF52A] text-xs tracking-[0.15em] font-bold">Materiały wizualne</p>
          </Reveal>
          <Reveal delay={0.25} color="#ffffff">
            <h2 class="cs-gallery-heading mt-2">Dokumentacja procesu</h2>
          </Reveal>
        </div>

        <!-- Row 1: 1 wide + 1 narrow -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-5 mb-5 opacity-0" data-scroll-fade>
          <div class="md:col-span-8">
            <figure class="m-0 p-0">
              <div class="aspect-[16/9] rounded-2xl overflow-hidden border border-white/5 cs-placeholder">
                <div class="cs-placeholder-inner">
                  <div class="cs-placeholder-icon">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                  </div>
                  <p class="cs-placeholder-label cs-placeholder-label--sm">Streamwall — wielostrumieniowy dashboard operatora</p>
                </div>
              </div>
