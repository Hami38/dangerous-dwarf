---
/* src/components/PageTransition.astro */
---

<div id="curtain" aria-hidden="true">
  <div class="strip" style="--i:0"></div>
  <div class="strip" style="--i:1"></div>
  <div class="strip" style="--i:2"></div>
  <div class="strip" style="--i:3"></div>
  <div class="strip" style="--i:4"></div>
  <div class="strip" style="--i:5"></div>
</div>

<style>
  #curtain {
    position: fixed;
    inset: 0;
    z-index: 9000;
    pointer-events: none;
  }

  .strip {
    position: absolute;
    top: 0;
    bottom: 0;
    width: calc(100% / 6 + 2px);
    left: calc(var(--i) * (100% / 6));
    background: #BAF52A;
    transform: translateY(105%);
    will-change: transform;
  }

  html.curtain-ready .strip {
    transform: translateY(0%) !important;
    transition: none !important;
  }
</style>

<script>
  const EASE    = 'cubic-bezier(0.87, 0, 0.13, 1)';
  const STAGGER = 55;
  const IN_MS   = 580;
  const OUT_MS  = 500;

  const strips = Array.from(document.querySelectorAll<HTMLElement>('.strip'));

  /* ── Zakrycie: lewo → prawo ────────────────────────────────────────
     Reset do pozycji startowej wykonujemy TUTAJ (a nie po odsłonięciu)
     żeby uniknąć mignięcia przy przeskoku GPU z -105% → 105%.        */
  function cover(onDone: () => void) {
    // 1. Resetuj do dołu bez animacji
    strips.forEach(strip => {
      strip.style.transition = 'none';
      strip.style.transform  = 'translateY(105%)';
    });

    // 2. Dwa rAF-y: poczekaj aż przeglądarka zastosuje reset, potem animuj
    requestAnimationFrame(() => requestAnimationFrame(() => {
      strips.forEach((strip, i) => {
        setTimeout(() => {
          strip.style.transition = `transform ${IN_MS}ms ${EASE}`;
          strip.style.transform  = 'translateY(0%)';
        }, i * STAGGER);
      });

      const total = (strips.length - 1) * STAGGER + IN_MS;
      setTimeout(onDone, total + 30);
    }));
  }

  /* ── Odsłonięcie: prawo → lewo (odwrócona kolejność = kontynuacja
     ruchu od ostatniego który wjechał do pierwszego który wjechał).
     Paski NIE są tu resetowane — reset odbywa się w kolejnym cover().  */
  function reveal() {
    [...strips].reverse().forEach((strip, i) => {
      setTimeout(() => {
        strip.style.transition = `transform ${OUT_MS}ms ${EASE}`;
        strip.style.transform  = 'translateY(-105%)';
      }, i * STAGGER);
    });

    const total = (strips.length - 1) * STAGGER + OUT_MS;
    setTimeout(() => {
      document.documentElement.classList.remove('curtain-ready');
      document.documentElement.classList.remove('no-preloader');
      window.dispatchEvent(new CustomEvent('curtainDone'));
    }, total + 50);
  }

  /* ── Init ──────────────────────────────────────────────────────────── */
  if (sessionStorage.getItem('ct')) {
    sessionStorage.removeItem('ct');

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        requestAnimationFrame(() => requestAnimationFrame(reveal));
      });
    } else {
      requestAnimationFrame(() => requestAnimationFrame(reveal));
    }
  }

  /* ── Przechwytywanie kliknięć ──────────────────────────────────────── */
  document.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a[href]') as HTMLAnchorElement | null;
    if (!link) return;

    const href = link.getAttribute('href') ?? '';

    if (
      !href ||
      href.startsWith('#') ||
      href.startsWith('http') ||
      href.startsWith('//') ||
      href.startsWith('mailto') ||
      href.startsWith('tel') ||
      link.target === '_blank'
    ) return;

    if (new URL(href, window.location.href).pathname === window.location.pathname) return;

    e.preventDefault();
    cover(() => {
      sessionStorage.setItem('ct', '1');
      sessionStorage.setItem('np', '1'); // pomiń preloader na stronie docelowej
      window.location.href = href;
    });
  });
</script>
