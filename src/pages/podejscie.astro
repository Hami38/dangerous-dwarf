---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Reveal from '../components/Reveal.astro';

const pillar1Items = [
  {
    heading: "Struktura ponad estetyką",
    body: "Tam, gdzie regulacje prawne (KNF, EBA, GDPR), ograniczenia technologiczne i legacy systemów przytłaczają proces, wprowadzam porządek. Projektuję architekturę informacji, która mityguje ryzyko błędów operacyjnych i pozwala użytkownikowi skupić się na decyzji, a nie na walce z interfejsem."
  },
  {
    heading: "Design jako mitygacja ryzyka",
    body: "W bankowości i systemach bezpieczeństwa prostota to nie minimalizm wizualny — to redukcja obciążenia poznawczego. Buduję systemy, w których każda interakcja jest bezpieczna, przewidywalna i zgodna z najwyższymi standardami compliance."
  },
  {
    heading: "Data-Informed Strategy",
    body: "Dane mówią mi, co się dzieje, ale badania jakościowe i psychologia finansowa tłumaczą, dlaczego. Analityka waliduje hipotezy, lecz to głębokie rozumienie Big Picture pozwala projektować rozwiązania, które wyprzedzają potrzeby rynku."
  }
];

const pillar2Items = [
  {
    heading: "Kultura oparta na dowodach",
    body: 'Usuwam frazę „wydaje mi się” ze słownika projektowego. Wdrażam procesy, w których decyzje są wynikiem badań i twardych danych rynkowych — design staje się przewidywalnym procesem biznesowym, a nie subiektywną opinią jednostki.'
  },
  {
    heading: "Facylitacja i współpraca",
    body: "Jako Product Lead usuwam bariery komunikacyjne między IT, Business i Compliance. Prowadzę warsztaty i procesy decyzyjne tak, aby każda funkcja produktu realizowała konkretny cel biznesowy przy zachowaniu najwyższej jakości UX."
  },
  {
    heading: "Mentoring i skalowanie dojrzałości",
    body: "Buduję zespoły rozumiejące kontekst biznesowy swojej pracy. Inwestuję w samodzielność projektantów — uczę strategicznego myślenia i bronienia decyzji argumentami merytorycznymi, nie osobistym gustem."
  }
];

const whyMe = [
  {
    number: "01",
    heading: "Zrozumienie regulacji",
    body: "Nie boję się compliance. Traktuję ramy prawne jako zestaw parametrów projektowych — przekształcam ograniczenia w przewagę konkurencyjną produktu."
  },
  {
    number: "02",
    heading: "Odpowiedzialność za KPI",
    body: "Nie dostarczam makiet. Dostarczam rozwiązania z realnym wpływem na konwersję, retencję i bezpieczeństwo operacyjne. Każda decyzja jest mierzalna."
  },
  {
    number: "03",
    heading: "12 lat praktyki",
    body: "Wiem, kiedy walczyć o detale, a kiedy skupić się na szybkim dowiezieniu wartości biznesowej. Time-to-Market i jakość nie muszą być w konflikcie."
  }
];
---

<Layout title="Podejście | Kamil Wardak">

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        window.dispatchEvent(new CustomEvent('preloaderFinished'));
      }, 100);
    });
  </script>

  <div class="bg-[#0c0a09] min-h-screen">

    <!-- ═══════════════════════════════════════════════════════════════════════
         HERO
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="relative px-6 pt-16 md:pt-28 pb-20 md:pb-32 overflow-hidden">

      <div class="pd-hero-glow" aria-hidden="true"></div>
      <div class="pd-hero-grid" aria-hidden="true"></div>

      <div class="max-w-4xl mx-auto relative z-10">

        <div class="mb-5 opacity-0" data-hero-fade style="--delay: 0s">
          <Reveal delay={0} color="#BAF52A">
            <p class="pd-overline">Podejście</p>
          </Reveal>
        </div>

        <h1 class="pd-headline opacity-0" data-hero-fade style="--delay: 0.07s">
          Strategia to rzemiosło<br/>
          <span class="pd-headline-accent">wprowadzania struktury w chaos.</span>
        </h1>

        <p class="pd-lead max-w-2xl mt-6 opacity-0" data-hero-fade style="--delay: 0.14s">
          Moje podejście opiera się na dwóch filarach: precyzyjnej analizie skomplikowanych
          ekosystemów oraz budowaniu kultury projektowej, w której design jest mierzalnym
          partnerem biznesu. Nie szukam najprostszych rozwiązań — szukam tych najskuteczniejszych.
        </p>

        <!-- Pillar navigation anchors -->
        <div class="flex flex-col md:flex-row md:flex-wrap md:items-center gap-4 mt-10 opacity-0" data-hero-fade style="--delay: 0.21s">
          <a href="#fragmentacja-big-picture" class="pd-anchor-btn pd-anchor-btn--primary">
            <span>01 · Fragmentacja & Big Picture</span>
            <svg class="pd-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 5v14m-7-7 7 7 7-7"/>
            </svg>
          </a>
          <a href="#zarzadzanie-przywodztwo" class="pd-anchor-btn pd-anchor-btn--secondary">
            <span>02 · Zarządzanie & Przywództwo</span>
            <svg class="pd-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 5v14m-7-7 7 7 7-7"/>
            </svg>
          </a>
        </div>

        <!-- Divider with glow -->
        <div class="pd-hero-divider mt-16 md:mt-20 opacity-0" data-hero-fade style="--delay: 0.28s" aria-hidden="true"></div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         FILAR I — Fragmentacja & Big Picture
    ════════════════════════════════════════════════════════════════════════ -->
    <section
      id="fragmentacja-big-picture"
      class="pd-pillar-section pd-pillar--cool relative px-6 py-24 md:py-32 overflow-hidden"
    >
      <span class="pd-bg-num" aria-hidden="true">01</span>
      <div class="pd-pillar-glow pd-pillar-glow--a" aria-hidden="true"></div>

      <div class="max-w-4xl mx-auto relative z-10">

        <!-- Section header -->
        <div class="mb-14 md:mb-20">

          <div class="opacity-0 mb-5" data-scroll-fade>
            <span class="pd-pill">Filar I</span>
          </div>

          <div class="opacity-0" data-scroll-fade style="--fade-delay: 0.08s">
            <p class="pd-pillar-tag">Fragmentacja & Big Picture</p>
          </div>

          <h2 class="pd-pillar-heading opacity-0" data-scroll-fade style="--fade-delay: 0.16s">
            Projektowanie logiki<br class="hidden md:block"/>
            w środowiskach wysokiej złożoności.
          </h2>

          <p class="pd-pillar-intro opacity-0" data-scroll-fade style="--fade-delay: 0.24s">
            W sektorze finansowym i systemach krytycznych złożoność nie jest przeszkodą —
            jest naturalnym środowiskiem pracy. Moim zadaniem jest dekonstrukcja tej złożoności
            i zamiana jej w intuicyjne, bezpieczne procesy.
          </p>

        </div>

        <!-- Items grid -->
        <div class="pd-items-grid">
          {pillar1Items.map((item, i) => (
            <div
              class="pd-item opacity-0"
              data-scroll-fade
              style={`--fade-delay: ${0.08 + i * 0.1}s`}
            >
              <p class="pd-item-num">{String(i + 1).padStart(2, '0')}</p>
              <div class="pd-item-line" aria-hidden="true"></div>
              <h3 class="pd-item-heading">{item.heading}</h3>
              <p class="pd-item-body">{item.body}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         FILAR II — Zarządzanie & Przywództwo
    ════════════════════════════════════════════════════════════════════════ -->
    <section
      id="zarzadzanie-przywodztwo"
      class="pd-pillar-section pd-pillar--warm relative px-6 py-24 md:py-32 overflow-hidden"
    >
      <span class="pd-bg-num pd-bg-num--right" aria-hidden="true">02</span>
      <div class="pd-pillar-glow pd-pillar-glow--b" aria-hidden="true"></div>

      <div class="max-w-4xl mx-auto relative z-10">

        <!-- Section header -->
        <div class="mb-14 md:mb-20">

          <div class="opacity-0 mb-5" data-scroll-fade>
            <span class="pd-pill pd-pill--alt">Filar II</span>
          </div>

          <div class="opacity-0" data-scroll-fade style="--fade-delay: 0.08s">
            <p class="pd-pillar-tag">Zarządzanie & Przywództwo</p>
          </div>

          <h2 class="pd-pillar-heading opacity-0" data-scroll-fade style="--fade-delay: 0.16s">
            Design to sport zespołowy.<br class="hidden md:block"/>
            Moja rola to facylitacja zwycięstwa.
          </h2>

          <p class="pd-pillar-intro opacity-0" data-scroll-fade style="--fade-delay: 0.24s">
            Lider UX w dużej organizacji to nie tylko strażnik jakości projektowej —
            to przede wszystkim łącznik między biznesem, technologią a użytkownikiem.
            Most, który sprawia, że decyzje mają sens dla wszystkich stron.
          </p>

        </div>

        <!-- Items grid -->
        <div class="pd-items-grid">
          {pillar2Items.map((item, i) => (
            <div
              class="pd-item pd-item--alt opacity-0"
              data-scroll-fade
              style={`--fade-delay: ${0.08 + i * 0.1}s`}
            >
              <p class="pd-item-num pd-item-num--alt">{String(i + 1).padStart(2, '0')}</p>
              <div class="pd-item-line pd-item-line--alt" aria-hidden="true"></div>
              <h3 class="pd-item-heading">{item.heading}</h3>
              <p class="pd-item-body">{item.body}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         WHY ME
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="relative px-6 py-24 md:py-32 overflow-hidden">

      <div class="max-w-4xl mx-auto">

        <div class="mb-16 md:mb-20 opacity-0" data-scroll-fade>
          <p class="text-[#BAF52A] text-xs tracking-[0.15em] font-bold mb-5 uppercase">
            Dlaczego ja?
          </p>
          <h2 class="pd-section-heading">
            Dlaczego potrzebujesz UX&nbsp;Stratega<br class="hidden md:block"/>
            na tym etapie?
          </h2>
        </div>

        <div class="pd-why-grid">
          {whyMe.map((item, i) => (
            <div
              class="pd-why-card opacity-0"
              data-scroll-fade
              style={`--fade-delay: ${0.06 + i * 0.1}s`}
            >
              <p class="pd-why-num">{item.number}</p>
              <h3 class="pd-why-heading">{item.heading}</h3>
              <p class="pd-why-body">{item.body}</p>
            </div>
          ))}
        </div>

        <!-- Closing quote -->
        <div class="pd-quote opacity-0 mt-16 md:mt-20" data-scroll-fade style="--fade-delay: 0.3s">
          <div class="pd-quote-bar" aria-hidden="true"></div>
          <p class="pd-quote-kicker">Filozofia pracy</p>
          <p class="pd-quote-text">
            "Strategia bez egzekucji to marzenie. Egzekucja bez strategii to koszmar.
            Moje podejście łączy oba światy — bo tylko tak design staje się realną
            przewagą konkurencyjną, a nie kosztem projektowym."
          </p>
        </div>

      </div>
    </section>

    <Footer />
  </div>

</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 90px;
  }
</style>

<style>

  /* ─── Hero background elements ───────────────────────────────────────────── */

  .pd-hero-glow {
    position: absolute;
    top: -100px;
    right: -180px;
    width: 650px;
    height: 650px;
    background: radial-gradient(ellipse at center, rgba(186,245,42,0.065) 0%, transparent 65%);
    pointer-events: none;
  }

  .pd-hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(186,245,42,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(186,245,42,0.03) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 40%, transparent 100%);
    pointer-events: none;
  }

  /* ─── Overline ───────────────────────────────────────────────────────────── */

  .pd-overline {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #BAF52A;
    margin: 0;
  }

  /* ─── Hero headline ──────────────────────────────────────────────────────── */

  .pd-headline {
    font-size: clamp(2.5rem, 7vw, 4.8rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin: 0;
  }

  .pd-headline-accent {
    background: linear-gradient(135deg, #BAF52A 0%, #e8ff8a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ─── Lead text ──────────────────────────────────────────────────────────── */

  .pd-lead {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    line-height: 1.8;
    color: rgba(255,255,255,0.5);
    margin: 0;
  }

  /* ─── Anchor navigation buttons ─────────────────────────────────────────── */

  .pd-anchor-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 13px 26px;
    border-radius: 9999px;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
    text-decoration: none;
    white-space: nowrap;
    width: 100%;
  }

  @media (min-width: 768px) {
    .pd-anchor-btn {
      width: auto;
    }
  }

  .pd-btn-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .pd-anchor-btn:hover .pd-btn-icon {
    transform: translateY(3px);
  }

  .pd-anchor-btn--primary {
    background-color: #BAF52A;
    color: #000000;
  }

  .pd-anchor-btn--primary:hover {
    background-color: #000;
    color: #BAF52A;
    box-shadow: 0 0 0 1px #BAF52A, 0 0 28px rgba(186,245,42,0.18);
  }

  .pd-anchor-btn--secondary {
    background-color: transparent;
    color: rgba(255,255,255,0.65);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .pd-anchor-btn--secondary:hover {
    color: #BAF52A;
    border-color: rgba(186,245,42,0.4);
    background-color: rgba(186,245,42,0.04);
  }

  /* ─── Hero divider ───────────────────────────────────────────────────────── */

  .pd-hero-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(186,245,42,0.2), rgba(255,255,255,0.06), transparent);
  }

  /* ─── Pillar sections ────────────────────────────────────────────────────── */

  .pd-pillar-section {
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .pd-pillar--cool {
    background: #0c0a09;
  }

  .pd-pillar--warm {
    background: #0f0d0b;
  }

  /* ─── Background large number ────────────────────────────────────────────── */

  .pd-bg-num {
    position: absolute;
    top: -3rem;
    left: -1rem;
    font-size: clamp(10rem, 22vw, 18rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.06em;
    color: var(--brand-main);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .pd-bg-num--right {
    left: auto;
    right: -2rem;
  }

  /* ─── Pillar glows ───────────────────────────────────────────────────────── */

  .pd-pillar-glow {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
  }

  .pd-pillar-glow--a {
    top: -80px;
    right: -120px;
    width: 560px;
    height: 560px;
    background: radial-gradient(ellipse, rgba(186,245,42,0.05) 0%, transparent 65%);
  }

  .pd-pillar-glow--b {
    bottom: -80px;
    left: -120px;
    width: 560px;
    height: 560px;
    background: radial-gradient(ellipse, rgba(186,245,42,0.045) 0%, transparent 65%);
  }

  /* ─── Pill badges ────────────────────────────────────────────────────────── */

  .pd-pill {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: #BAF52A;
    background: rgba(186,245,42,0.1);
    border: 1px solid rgba(186,245,42,0.28);
    border-radius: 9999px;
    padding: 4px 14px;
  }

  .pd-pill--alt {
    color: #a8e6ff;
    background: rgba(168,230,255,0.08);
    border-color: rgba(168,230,255,0.2);
  }

  /* ─── Pillar tag ─────────────────────────────────────────────────────────── */

  .pd-pillar-tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.5);
    margin: 0 0 14px;
  }

  /* ─── Pillar heading ─────────────────────────────────────────────────────── */

  .pd-pillar-heading {
    font-size: clamp(1.75rem, 4.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin: 0 0 1.25rem;
  }

  /* ─── Pillar intro paragraph ─────────────────────────────────────────────── */

  .pd-pillar-intro {
    font-size: clamp(0.9rem, 1.8vw, 1rem);
    line-height: 1.8;
    color: rgba(255,255,255,0.55);
    margin: 0;
    max-width: 620px;
  }

  /* ─── Items grid ─────────────────────────────────────────────────────────── */

  .pd-items-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 20px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .pd-items-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ─── Item card ──────────────────────────────────────────────────────────── */

  .pd-item {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px 24px;
    background: rgba(12,10,9,1);
    transition: background 0.35s ease;
    position: relative;
  }

  .pd-item:hover {
    background: rgba(186,245,42,0.04);
  }

  .pd-item--alt:hover {
    background: rgba(168,230,255,0.025);
  }

  .pd-item-num {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: #BAF52A;
    margin: 0;
  }

  .pd-item-num--alt {
    color: #a8e6ff;
  }

  .pd-item-line {
    width: 24px;
    height: 2px;
    background: linear-gradient(90deg, #BAF52A, transparent);
    border-radius: 9999px;
    margin: 2px 0 4px;
    transition: width 0.4s ease;
  }

  .pd-item:hover .pd-item-line {
    width: 40px;
  }

  .pd-item-line--alt {
    background: linear-gradient(90deg, #a8e6ff, transparent);
  }

  .pd-item-heading {
    font-size: 0.93rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.35;
    margin: 0;
  }

  .pd-item-body {
    font-size: 0.84rem;
    line-height: 1.75;
    color: #a8a29e;
    margin: 0;
  }

  /* ─── Section heading ────────────────────────────────────────────────────── */

  .pd-section-heading {
    font-size: clamp(1.8rem, 4.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin: 0;
  }

  /* ─── Why Me grid ────────────────────────────────────────────────────────── */

  .pd-why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 20px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .pd-why-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ─── Why card ───────────────────────────────────────────────────────────── */

  .pd-why-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 32px 28px;
    background: rgba(12,10,9,1);
    transition: background 0.35s ease;
  }

  .pd-why-card:hover {
    background: rgba(186,245,42,0.04);
  }

  .pd-why-num {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 4px;
    background: linear-gradient(135deg, #BAF52A 0%, #e8ff8a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pd-why-heading {
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.3;
    margin: 0;
  }

  .pd-why-body {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #a8a29e;
    margin: 0;
  }

  /* ─── Quote block ────────────────────────────────────────────────────────── */

  .pd-quote {
    position: relative;
    padding: 32px 36px 32px 44px;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 20px;
    background: rgba(186,245,42,0.02);
  }

  .pd-quote-bar {
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 3px;
    background: linear-gradient(180deg, transparent, #BAF52A, transparent);
    border-radius: 9999px;
  }

  .pd-quote-kicker {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #BAF52A;
    margin: 0 0 12px;
  }

  .pd-quote-text {
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    font-weight: 500;
    font-style: italic;
    line-height: 1.8;
    color: rgba(255,255,255,0.65);
    margin: 0;
  }

  /* ─── Animations ─────────────────────────────────────────────────────────── */

  [data-hero-fade] {
    transform: translateY(16px);
    transition:
      opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-hero-fade].in-view {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  [data-scroll-fade] {
    transform: translateY(18px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-scroll-fade].in-view {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

</style>

<script>
  import gsap from 'gsap';

  // ── Hero fade-ins ────────────────────────────────────────────────────────
  const heroFadeEls = document.querySelectorAll<HTMLElement>('[data-hero-fade]');
  heroFadeEls.forEach((el) => {
    const delay = parseFloat(getComputedStyle(el).getPropertyValue('--delay') || '0');
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.7,
      delay: 0.2 + delay,
      ease: 'power3.out',
    });
  });

  // ── Scroll fade-ins ──────────────────────────────────────────────────────
  const scrollFadeEls = document.querySelectorAll<HTMLElement>('[data-scroll-fade]');

  const scrollObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseFloat(
            getComputedStyle(el).getPropertyValue('--fade-delay') || '0'
          );
          setTimeout(() => el.classList.add('in-view'), delay * 1000);
          scrollObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -4% 0px' }
  );

  scrollFadeEls.forEach((el) => scrollObserver.observe(el));
</script>
