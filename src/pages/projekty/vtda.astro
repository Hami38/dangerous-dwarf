---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import Footer from '../../components/Footer.astro';

const project = {
  overline: "Bezpieczeństwo krytyczne / Deep Tech",
  title: "VTDA — Wirtualny Asystent Maszynisty",
  subtitle: "Architektura decyzji i logiki bezpieczeństwa w transporcie kolejowym. Redukcja ryzyka incydentów o 20% w 6-miesięcznym pilocie.",
  role: "Lead Product Designer / UX Architect",
  client: "Infracert",
  year: "2022",
  scope: "Product Design · Safety-Critical UX · Human Factors",
};

const challenges = [
  {
    number: "01",
    title: "Kryzys uwagi i reaktywność",
    description: 'Maszyniści pracowali w modelu reaktywnym — odpowiadali na alerty zamiast przewidywać zdarzenia. Istniejące systemy wymuszały rolę procesora danych. Przy prędkościach kolejowych to krytyczny błąd architektoniczny.',
  },
  {
    number: "02",
    title: "Paraliż decyzyjny — pułapka Szklanego Kokpitu",
    description: 'Pierwsze prototypy wzorowane na systemach lotniczych — setki parametrów telemetrycznych na jednym ekranie — generowały paraliż decyzyjny. Odnalezienie kluczowej informacji odciągało wzrok od torów. Potrzebna była redukcja o 60%.',
  },
  {
    number: "03",
    title: "Fizyka środowiska kabiny",
    description: 'Standardowy Dark Mode okazał się niebezpieczny — jasne elementy UI odbijały się w szybie lokomotywy nocą, przesłaniając widoczność torów. Projektowanie musiało dosłownie walczyć z fizyką środowiska.',
  },
];

const results = [
  { value: "-20%", label: "ryzyka incydentów u regularnych użytkowników systemu w pilocie" },
  { value: "-5%", label: "wypadkowości w skali całych organizacji kolejowych w 6 miesiącach" },
  { value: "50+", label: "operatorów kolejowych wdrożyło system, potwierdzając realną wartość produktu" },
  { value: "120+", label: "ekranów w skalowalnej, modularnej architekturze Safety-Critical" },
];

const nextProjects = [
  {
    overline: "Finanse / Strategia UX",
    title: "BLIK dla Biznesu w ING",
    description: "Adaptacja retailowych wzorców płatniczych do złożonego ekosystemu bankowości korporacyjnej.",
    href: "/projekty/blik-dla-biznesu",
    image: "/images/ing/KV_blik.webp",
  },
  {
    overline: "Bezpieczeństwo / Computer Vision",
    title: "System reidentyfikacji osób dla infrastruktury krytycznej",
    description: "Integracja zaawansowanego rzemiosła UX z systemami wizyjnymi AI. 20% ROI w 6 miesięcy.",
    href: "/projekty/reid",
    image: "/images/reid/hero_reid.webp",
  },
  {
    overline: "MedTech / IoT / Product Design",
    title: "Tabbox: Inteligentny system farmakoterapii",
    description: "Ekosystem łączący fizyczny dozownik leków z aplikacją mobilną.",
    href: "#case-healthtech",
  },
];
---

<Layout title={`${project.title} | Kamil Wardak`}>

  <!-- ─── PRELOADER BYPASS ───────────────────────────────────────────────── -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        window.dispatchEvent(new CustomEvent('preloaderFinished'));
      }, 100);
    });
  </script>

  <div class="bg-[#0c0a09] min-h-screen">

    <!-- ─── SPACER pod header ──────────────────────────────────────────────── -->
    <div class="h-20"></div>

    <!-- ═══════════════════════════════════════════════════════════════════════
         HERO SECTION
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-hero relative px-6 pt-0 pb-0 md:pt-16 overflow-hidden">
      <div class="max-w-4xl mx-auto">

        <!-- Breadcrumb -->
        <div class="cs-breadcrumb mb-10 opacity-0" data-hero-fade style="--delay: 0s">
          <a href="/prace" class="cs-back-link group inline-flex items-center gap-2 text-white/40 text-sm font-medium transition-colors duration-300 hover:text-[#BAF52A]">
            <svg class="cs-back-arrow transition-transform duration-300 group-hover:-translate-x-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14m-7-7-7 7 7 7"/>
            </svg>
            <span>Wszystkie projekty</span>
          </a>
        </div>

        <!-- Overline label -->
        <div class="mb-5 opacity-0" data-hero-fade style="--delay: 0.05s">
          <Reveal trigger="onLoad" delay={0.15} color="#BAF52A">
            <p class="cs-overline text-[#BAF52A] text-xs tracking-[0.15em] font-bold">{project.overline}</p>
          </Reveal>
        </div>

        <!-- Main title -->
        <div class="mb-6">
          <Reveal trigger="onLoad" delay={0.3} duration={0.8} color="#ffffff">
            <h1 class="cs-hero-title text-white font-bold leading-[1.05] tracking-tight">
              {project.title}
            </h1>
          </Reveal>
        </div>

        <!-- Subtitle -->
        <div class="max-w-2xl mb-12">
          <Reveal trigger="onLoad" delay={0.55} color="#a8a29e">
            <p class="cs-hero-subtitle text-stone-400 text-lg md:text-xl font-medium leading-relaxed">
              {project.subtitle}
            </p>
          </Reveal>
        </div>

        <!-- Meta strip -->
        <div class="cs-meta-strip opacity-0" data-hero-fade style="--delay: 0.7s">
          <div class="cs-meta-item">
            <span class="cs-meta-label">Rola</span>
            <span class="cs-meta-value">{project.role}</span>
          </div>
          <div class="cs-meta-divider"></div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Klient</span>
            <span class="cs-meta-value">{project.client}</span>
          </div>
          <div class="cs-meta-divider"></div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Rok</span>
            <span class="cs-meta-value">{project.year}</span>
          </div>
          <div class="cs-meta-divider"></div>
          <div class="cs-meta-item">
            <span class="cs-meta-label">Zakres</span>
            <span class="cs-meta-value">{project.scope}</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── NOTA O POUFNOŚCI ─────────────────────────────────────────────── -->
    <section class="px-6 pt-8 pb-0">
      <div class="max-w-4xl mx-auto">
        <div class="cs-confidentiality-note opacity-0" data-hero-fade style="--delay: 0.85s">
          <svg class="cs-conf-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <p>
            <strong>Nota o charakterze projektu:</strong> VTDA jest systemem klasy Safety-Critical. Prezentowane materiały wizualne pochodzą z fazy projektowej i zostały zanonimizowane. Niniejsze case study koncentruje się na architekturze decyzji UX, psychologii bezpieczeństwa i mierzalnym wpływie operacyjnym — nie na finalnych detalach produkcyjnych interfejsu.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── HERO IMAGE ─────────────────────────────────────────────────────── -->
    <section class="cs-hero-image-section px-6 pt-12 pb-0">
      <div class="max-w-4xl mx-auto">
        <div class="cs-hero-img-wrapper opacity-0" data-scroll-fade>
          <div class="aspect-[16/7] rounded-3xl overflow-hidden border border-white/5">
            <img src="/images/vtda/VTDA_01.webp" alt="VTDA — wirtualny asystent maszynisty, mockup tabletu w kabinie lokomotywy" class="w-full h-full object-cover cs-img" loading="eager" />
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 1 — KONTEKST
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section px-6 pt-28 md:pt-36 pb-0">
      <div class="max-w-4xl mx-auto">

        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">

          <!-- Left: Number + heading -->
          <div class="md:col-span-5">
            <Reveal delay={0.1} color="#BAF52A">
              <p class="cs-section-number">01</p>
            </Reveal>
            <Reveal delay={0.25} color="#ffffff">
              <h2 class="cs-section-heading mt-3">
                System jako proaktywny asystent, nie pasywny wyświetlacz
              </h2>
            </Reveal>
          </div>

          <!-- Right: Body text -->
          <div class="md:col-span-7">
            <Reveal delay={0.35} color="#a8a29e">
              <p class="cs-body-text mb-6">
                W kabinie lokomotywy głównym wyzwaniem nie jest brak danych — jest ich nadmiar. Maszyniści pracowali reaktywnie: odpowiadali na alerty zamiast przewidywać zdarzenia. Przy prędkościach kolejowych reaktywność to krytyczny błąd bezpieczeństwa.
              </p>
            </Reveal>
            <Reveal delay={0.5} color="#a8a29e">
              <p class="cs-body-text">
                Moją diagnozą UX było to, że istniejące systemy wymuszały na człowieku rolę „procesora danych". Celem projektu było przesunięcie roli systemu z biernego wyświetlacza na proaktywnego asystenta, który zarządza uwagą maszynisty i filtruje szum informacyjny — szczególnie w sytuacjach wysokiego stresu.
              </p>
            </Reveal>
          </div>

        </div>

        <!-- Context images -->
        <div class="cs-img-wrapper mt-16 opacity-0" data-scroll-fade>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <figure class="m-0 p-0">
              <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/5">
                <img src="/images/vtda/VTDA_04.webp" alt="Sterownia maszynisty - agregacja bodźców użytkownika" class="w-full h-full object-cover cs-img" loading="lazy" />
              </div>
              <figcaption class="cs-img-caption">Sterownia maszynisty - agregacja bodźców użytkownika</figcaption>
            </figure>
            <figure class="m-0 p-0">
              <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/5">
                <img src="/images/vtda/VTDA_13.webp" alt="Ewolucja Dashboardu — wersja finalna po redukcji o 60%" class="w-full h-full object-cover cs-img" loading="lazy" />
              </div>
              <figcaption class="cs-img-caption">Ewolucja Dashboardu — wersja finalna po redukcji widoku</figcaption>
            </figure>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 2 — WYZWANIA
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section cs-section--dark px-6 pt-28 md:pt-36 pb-28 md:pb-36">
      <div class="max-w-4xl mx-auto">

        <!-- Section header -->
        <div class="mb-16 md:mb-20">
          <Reveal delay={0.1} color="#BAF52A">
            <p class="cs-section-number">02</p>
          </Reveal>
          <Reveal delay={0.25} color="#ffffff">
            <h2 class="cs-section-heading mt-3 max-w-xl">
              Projektowanie pod presją fizyki i&nbsp;psychologii
            </h2>
          </Reveal>
          <Reveal delay={0.4} color="#a8a29e">
            <p class="cs-body-text max-w-2xl mt-4">
              Trzy wyzwania, z których każde mogło samodzielnie zdyskredytować produkt — albo kosztować życie.
            </p>
          </Reveal>
        </div>

        <!-- Challenge cards -->
        <div class="cs-challenges-grid">
          {challenges.map((ch, i) => (
            <div class="cs-challenge-card opacity-0" data-scroll-fade style={`--fade-delay: ${0.1 + i * 0.15}s`}>
              <div class="cs-challenge-number">{ch.number}</div>
              <div class="cs-challenge-content">
                <h3 class="cs-challenge-title">{ch.title}</h3>
                <p class="cs-challenge-desc">{ch.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Night mode image -->
        <div class="mt-20 opacity-0" data-scroll-fade style="--fade-delay: 0.3s">
          <figure class="m-0 p-0">
            <div class="aspect-[21/9] rounded-3xl overflow-hidden border border-white/5">
              <img src="/images/vtda/VTDA_11.webp" alt="Interfejs w trybie nocnym — ekstremalnie niska luminancja eliminująca refleksy na szybie" class="w-full h-full object-cover cs-img" loading="lazy" />
            </div>
            <figcaption class="cs-img-caption">Tryb nocny — ekstremalnie niska luminancja, barwy nieoddbijające się w szybie kabiny</figcaption>
          </figure>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 3 — PODEJŚCIE PROJEKTOWE
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section px-6 pt-28 md:pt-36 pb-0">
      <div class="max-w-4xl mx-auto">

        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">

          <!-- Left: Heading -->
          <div class="md:col-span-5 md:sticky md:top-28">
            <Reveal delay={0.1} color="#BAF52A">
              <p class="cs-section-number">03</p>
            </Reveal>
            <Reveal delay={0.25} color="#ffffff">
              <h2 class="cs-section-heading mt-3">
                Architektura decyzji i&nbsp;logiki bezpieczeństwa
              </h2>
            </Reveal>
            <Reveal delay={0.4} color="#a8a29e">
              <p class="cs-body-text mt-4">
                Każda decyzja projektowa miała uzasadnienie w psychologii bezpieczeństwa i fizyce środowiska. UX służył tu nie wygodzie, a utrzymaniu czujności i precyzji operatora.
              </p>
            </Reveal>
          </div>

          <!-- Right: Role items -->
          <div class="md:col-span-7 flex flex-col gap-10">

            <div class="cs-role-item opacity-0" data-scroll-fade style="--fade-delay: 0.1s">
              <div class="cs-role-tag">Progressive Disclosure & Fail-Fast Minimalism</div>
              <p class="cs-body-text mt-3">
                Zredukowałem widok główny o 60%. Widok krytyczny zawiera wyłącznie Prędkość, Następny Cel i Krzywą Hamowania. Szczegóły techniczne — parametry radia, diagnostyka — pojawiają się tylko na żądanie lub gdy system wykryje anomalię wymagającą interwencji. Mniej danych, więcej decyzji.
              </p>
              <div class="mt-6 opacity-0" data-scroll-fade style="--fade-delay: 0.2s">
                <figure class="m-0 p-0">
                  <div class="aspect-[16/7] rounded-2xl overflow-hidden border border-white/5">
                    <img src="/images/vtda/VTDA_14.webp" alt="Dashboard po redukcji — widok krytyczny z Progressive Disclosure" class="w-full h-full object-cover cs-img" loading="lazy" />
                  </div>
                  <figcaption class="cs-img-caption">Dashboard po redukcji — trzy elementy krytyczne, zero szumu</figcaption>
                </figure>
              </div>
            </div>

            <div class="cs-role-item opacity-0" data-scroll-fade style="--fade-delay: 0.2s">
              <div class="cs-role-tag">Psychologia bezpieczeństwa — Efekt Checklisty</div>
              <p class="cs-body-text mt-3">
                Mimo technicznej możliwości pełnej automatyzacji, zdecydowałem, że "System Check" przed odjazdem musi pozostać manualny. Maszynista musi fizycznie „zatwierdzić" gotowość składu. Checklist Effect buduje poczucie odpowiedzialności i zmusza do świadomego przejścia przez procedurę — UX służy tu utrzymaniu czujności, nie komfortu.
              </p>
              <div class="mt-6 opacity-0" data-scroll-fade style="--fade-delay: 0.25s">
                <figure class="m-0 p-0">
                  <div class="aspect-[16/7] rounded-2xl overflow-hidden border border-white/5">
                    <img src="/images/vtda/VTDA_08.webp" alt="Ekran manualnej weryfikacji systemu — Checklist Effect" class="w-full h-full object-cover cs-img" loading="lazy" />
                  </div>
                  <figcaption class="cs-img-caption">System Check — manualna weryfikacja jako celowy mechanizm budowania czujności</figcaption>
                </figure>
              </div>
            </div>

            <div class="cs-role-item opacity-0" data-scroll-fade style="--fade-delay: 0.3s">
              <div class="cs-role-tag">Architektura Guiding Rails — Widok Tunelowy</div>
              <p class="cs-body-text mt-3">
                Porzuciłem klasyczną mapę 2D na rzecz liniowej reprezentacji trasy (Guiding Rails). Pociąg porusza się wyłącznie w jednym kierunku — maszynistę nie interesuje otoczenie geograficzne, tylko to, co bezpośrednio na jego „nitce" toru. Skróciło to czas skanowania wzrokiem ekranu o 40%.
              </p>
            </div>

          </div>
        </div>

        <!-- Full-width mockup -->
        <div class="mt-20 opacity-0" data-scroll-fade>
          <figure class="m-0 p-0">
            <div class="aspect-[16/8] rounded-3xl overflow-hidden border border-white/5">
              <img src="/images/vtda/VTDA_09.webp" alt="VTDA — podsumowanie wyników systemu i statystyk pilotażu" class="w-full h-full object-cover cs-img" loading="lazy" />
            </div>
            <figcaption class="cs-img-caption">VTDA w działaniu — podsumowanie kluczowych wyników 6-miesięcznego pilotażu</figcaption>
          </figure>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEKCJA 4 — EFEKTY I WPŁYW BIZNESOWY
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-section cs-section--results px-6 pt-28 md:pt-36 pb-28 md:pb-36">
      <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="mb-16 md:mb-20">
          <Reveal delay={0.1} color="#BAF52A">
            <p class="cs-section-number">04</p>
          </Reveal>
          <Reveal delay={0.25} color="#ffffff">
            <h2 class="cs-section-heading mt-3">
              Wyniki mierzone bezpieczeństwem
            </h2>
          </Reveal>
          <Reveal delay={0.4} color="#a8a29e">
            <p class="cs-body-text max-w-2xl mt-4">
              Radykalne uproszczenie UX w przemyśle ciężkim przełożyło się na twarde wyniki operacyjne. W sektorze kolejowym, gdzie każdy incydent ma konsekwencje — 20% redukcja ryzyka to wynik wyjątkowy.
            </p>
          </Reveal>
        </div>

        <!-- Results grid -->
        <div class="cs-results-grid">
          {results.map((r, i) => (
            <div class="cs-result-card opacity-0" data-scroll-fade style={`--fade-delay: ${0.1 + i * 0.12}s`}>
              <div class="cs-result-value">{r.value}</div>
              <p class="cs-result-label">{r.label}</p>
            </div>
          ))}
        </div>

        <!-- Quote / highlight -->
        <div class="mt-20 opacity-0" data-scroll-fade style="--fade-delay: 0.2s">
          <div class="cs-quote-block">
            <div class="cs-quote-line" aria-hidden="true"></div>
            <blockquote class="cs-quote-text">
              "Zamiast przenosić do pociągów schematy znane z lotnictwa, skupiłem się na tym, czego maszynista naprawdę potrzebuje: nie więcej danych — lepszych decyzji w krytycznym momencie."
            </blockquote>
            <p class="cs-quote-source">Kamil Wardak · Lead Product Designer / UX Architect, projekt VTDA</p>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════════
         GALLERY STRIP
    ════════════════════════════════════════════════════════════════════════ -->
    <section class="cs-gallery-section px-6 pb-28 md:pb-36 overflow-hidden">
      <div class="max-w-4xl mx-auto">

        <div class="mb-12">
          <Reveal delay={0.1} color="#BAF52A">
            <p class="text-[#BAF52A] text-xs tracking-[0.15em] font-bold">Materiały wizualne</p>
          </Reveal>
          <Reveal delay={0.25} color="#ffffff">
            <h2 class="cs-gallery-heading mt-2">Dokumentacja procesu</h2>
          </Reveal>
        </div>

        <!-- Row 1: 1 wide + 1 narrow -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-5 mb-5 opacity-0" data-scroll-fade>
          <div class="md:col-span-8">
            <figure class="m-0 p-0">
              <div class="aspect-[16/9] rounded-2xl overflow-hidden border border-white/5">
                <img src="/images/vtda/VTDA_overview.webp" alt="Zestawienie widoków ekranów systemu VTDA" class="w-full h-full object-cover cs-img" loading="lazy" />
              </div>
              <figcaption class="cs-img-caption">Overview systemu VTDA</figcaption>
            </figure>
          </div>
          <div class="md:col-span-4">
            <figure class="m-0 p-0">
              <div class="aspect-[16/9] rounded-2xl overflow-hidden border border-white/5">
                <img src="/images/vtda/VTDA_user_flow.webp" alt="User flow systemu VTDA" class="w-full h-full object-cover cs-img" loading="lazy" />
              </div>
              <figcaption class="cs-img-caption">User flow systemu VTDA</figcaption>
            </figure>
          </div>
        </div>

        <!-- Row 2: 3 equal -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-5 opacity-0" data-scroll-fade style="--fade-delay: 0.15s">
          <figure class="m-0 p-0">
            <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/5">
              <img src="/images/vtda/VTDA_08.webp" alt="Ekran manualnej weryfikacji systemu — System Check" class="w-full h-full object-cover cs-img" loading="lazy" />
            </div>
            <figcaption class="cs-img-caption">System Check — manualna weryfikacja gotowości</figcaption>
          </figure>
          <figure class="m-0 p-0">
            <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/5">
              <img src="/images/vtda/VTDA_empathy_map.webp" alt="VTDA - mapa empatii" class="w-full h-full object-cover cs-img" loading="lazy" />
            </div>
