  }

  /* ─── Tool info ─────────────────────────────────────────────────────────── */

  .om-tool-info {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .om-tool-name {
    font-size: 0.82rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .om-tool-cat {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.5);
    margin: 2px 0 0;
    white-space: nowrap;
